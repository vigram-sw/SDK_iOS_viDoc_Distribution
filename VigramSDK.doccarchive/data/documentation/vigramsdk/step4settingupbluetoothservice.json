{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step4SettingUpBluetoothService"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"After completing ","type":"text"},{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","overridingTitleInlineContent":[{"text":"the authentication procedure","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"the authentication procedure"}]},{"text":", and ","type":"text"},{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters","overridingTitleInlineContent":[{"text":"the configuration flag settings","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"the configuration flag settings"}]},{"text":" you need to create the Bluetooth service and configure it. Let’s move on to these actions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A BluetoothService is used to handle bluetooth connections. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth"},{"text":" for more information.","type":"text"}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Your app will crash if its "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" doesn’t include usage description keys for the types of data it needs to access."},{"type":"text","text":" "},{"type":"text","text":"To access Core Bluetooth APIs:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"On apps linked on or after iOS 13, include the ","type":"text"},{"type":"codeVoice","code":"NSBluetoothAlwaysUsageDescription"},{"type":"text","text":" key."}]}]},{"content":[{"inlineContent":[{"text":"On iOS 12 and earlier, include ","type":"text"},{"type":"codeVoice","code":"NSBluetoothPeripheralUsageDescription"},{"text":".","type":"text"}],"type":"paragraph"}]}]}]},{"type":"heading","level":3,"text":"Step 1. Create an instance of the BluetoothService.","anchor":"Step-1-Create-an-instance-of-the-BluetoothService"},{"type":"paragraph","inlineContent":[{"text":"This service is required to work with the smartphone’s Bluetooth module (BLE).","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    var bluetoothService = Vigram.bluetoothService()"]},{"text":"Step 2. Run a scan to find RTK devices.","level":3,"anchor":"Step-2-Run-a-scan-to-find-RTK-devices","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to start searching for Bluetooth devices"}]},{"type":"codeListing","syntax":"swift","code":["    bluetoothService.startScan()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"startScan() can be called to start the scanning process for bluetooth peripherals."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once bluetooth capabilities are available, the service internally calls startScan() automatically."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"type":"text","text":" Don’t forget to include the appropriate permissions in the .plist file above. Otherwise, bluetooth will be blocked by iOS."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"fig13.png"}]},{"level":3,"type":"heading","text":"Step 3. Subscribe to the observeAvailableDevices publisher, which provides a list of discovered RTK devices.","anchor":"Step-3-Subscribe-to-the-observeAvailableDevices-publisher-which-provides-a-list-of-discovered-RTK-devices"},{"inlineContent":[{"text":"It is not possible to connect directly to viDoc without using Apple system libraries. Therefore, before connecting to viDoc (Peripheral), you need to find the corresponding CBPeripheral device and connect to it using CoreBluetooth - Apple’s library for working with Bluetooth.","type":"text"}],"type":"paragraph"},{"code":["    var subscription = Set<AnyCancellable>()","","    \/\/ A constant that stores a reference to the device we will","    \/\/ to connect.","    let device: CBPeripheral","","    bluetoothService.observeAvailableDevices()","        .sink { [weak self] devices in","            \/\/ the return value stores an array of found devices","            \/\/ (if no devices are found, it will return an empty array)","            if let firstDevice = devices.first {","                \/\/ We will connect to the first device found.","                self?.device = firstDevice","            }","        }.store(in: &subscription)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Return value:","type":"text"}],"type":"strong"},{"type":"text","text":" [CBPeripheral]"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","overridingTitleInlineContent":[{"type":"text","text":"CoreBluetooth"}],"isActive":true,"type":"reference","overridingTitle":"CoreBluetooth"},{"type":"text","text":" for more information."}]},{"text":"Step 4. Create a Peripheral instance.","level":3,"anchor":"Step-4-Create-a-Peripheral-instance","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once we have found the required device (CBPeripheral instance), we can create a Peripheral instance to work with viDoc functions and connect to it.","type":"text"}]},{"syntax":"swift","code":["    \/\/ A constant that stores a reference to the device we will","    \/\/ to connect.","    let device: CBPeripheral","","    \/\/ A variable that stores a reference to RTK device (our viDoc)","    var peripheral = Vigram.peripheral(device)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you want to collect support logs, configure "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Vigram\/Logger"},{"type":"text","text":" with a "},{"type":"codeVoice","code":".jsonl"},{"type":"text","text":" file."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A detailed description can be found in the "},{"type":"strong","inlineContent":[{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Use Support Logger section."}],"overridingTitle":"Use Support Logger section.","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"}]}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ A constant that stores a reference to the device we will","    \/\/ to connect.","    let device: CBPeripheral","","    \/\/ A variable that stores a reference to RTK device (our viDoc)","    var peripheral: Peripheral?","","    \/\/ A constant that stores a support log file path","    let logFile = createLogFile(nameDevice: device.name,","                                fileExtension: \"jsonl\", folder: \"SupportLog\/basic\")","","    \/\/ Configure support logging once","    try Vigram.Logger(url: logFile, mode: .basic)","","    \/\/ Create peripheral instance","    peripheral = Vigram.peripheral(device)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you want to use a custom configuration, create one."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For more information, see "},{"type":"strong","inlineContent":[{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Use the Peripheral Configuration."}],"overridingTitle":"Use the Peripheral Configuration.","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration"}]}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ A constant that stores a reference to the device we will","    \/\/ to connect.","    let device: CBPeripheral","","    \/\/ A constant that stores a peripheral configuration","    let peripheralConfiguration =","            PeripheralConfiguration(rateOfChangeMessages: .hertz7,","                                    dynamicType: .stationary)","","    \/\/ A constant that stores a reference to RTK device (our viDoc)","    let peripheral =","            Vigram.peripheral(device,","                              configuration: peripheralConfiguration)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Or with support logger and configuration:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ A variable that stores a reference to the device we will","    \/\/ to connect.","    let device: CBPeripheral","","    \/\/ A variable that stores a reference to RTK device (our viDoc)","    var peripheral: Peripheral?","","    let peripheralConfiguration =","        PeripheralConfiguration(rateOfChangeMessages: .hertz7,","                                dynamicType: .stationary)","","    try Vigram.Logger(url: logFile, mode: .basic)","    peripheral =","        Vigram.peripheral(device,","                          configuration: peripheralConfiguration)"],"type":"codeListing"},{"anchor":"Step-5-Connecting-to-CBPeripheral-and-starting-communication-with-Peripheral","text":"Step 5. Connecting to CBPeripheral and starting communication with Peripheral","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"After creating an instance of the Peripheral class and determining the current CBPeripheral device, it is necessary to connect to the CBPeripheral and start exchanging messages with the Peripheral."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Combine publishers set","var subscription = Set<AnyCancellable>()","","\/\/ A constant that stores a reference to the device we will","\/\/ to connect.","let device: CBPeripheral","","\/\/ A constant that stores a reference to RTK device (our viDoc)","let peripheral: Peripheral","","\/\/ Connect to current device","bluetoothService.connect(to: device.identifier)","    .sink(receiveCompletion: { [weak self] completion in","        switch completion {","        case .finished:","            \/\/ Connect successful","            guard let self else { return }","            \/\/ Start exchanging messages with the Peripheral","            self.peripheral","                .start()","                .sink(receiveCompletion: { completion in","                    switch completion {","                    case .finished:","                        \/\/ Successful connection.","                        \/\/ You can send requests and read responses","                        \/\/ from the viDoc.","                        break","                    case .failure(let error):","                        \/\/ Error connect to Peripheral","                    }","                }) { _ in }.store(in: &self.subscription)","        case .failure(let error):","            \/\/ Error connect to CBPeripheral","    }","}){ currentCBPeripheral in","    \/\/ do something with value","}.store(in: &subscription)"],"type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError"}],"type":"paragraph"},{"anchor":"Step-6-Disconnecting-from-the-device","text":"Step 6. Disconnecting from the device","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"To finish working with the device, you need to break the connection."}],"type":"paragraph"},{"syntax":"swift","code":["bluetoothService.disconnect()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The full listing is presented below"}],"type":"paragraph"},{"syntax":"swift","code":["import Combine","import CoreBluetooth","import VigramSDK","","final class YouVigramHelper: NSObject {","","    \/\/ Stored properties","","    private var subscription = Set<AnyCancellable>()","    private var peripheral: Peripheral?","    private var bluetoothService: BluetoothService?","    private var currentDevice: CBPeripheral?","","    \/\/ Init","","    public init() {","        super.init()","","        \/\/ Previous step 2. Can be moved to a separate function.","        authenticationSDK()","","        \/\/ Previous step 3. Can be moved to a separate function.","        setDefaultParameters()","    }","","    deinit {","        subscription.removeAll()","    }","","    \/\/ Private methods","","    private func setDefaultParameters() {","        Configuration.defaultRate = .hertz7","    }","","    private func authenticationSDK() {","        Vigram.initial(token: \"Your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    \/\/ Successful authentication","                    \/\/ You can send requests and read responses","                    \/\/ from the viDoc.","                    break","                case .failure(let error):","                    \/\/ Authentication failure","                    \/\/ AuthenticationError received","                    \/\/ Do something with error","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                \/\/ Received value: Result<Bool, AuthenticationError>","                switch resultAuthentication {","                    case .success:","                        \/\/ Successful authentication","                        self?.bluetoothService = Vigram.bluetoothService()","                        self?.startScanBluetooth()","                    case .failure(let error):","                        \/\/ Authentication failure","                        print(error.localizedDescription)","                }","            }.store(in: &subscription)","    }","","    private func startScanBluetooth() {","        bluetoothService?.startScan()","        bluetoothService?.observeAvailableDevices()","            .sink { [weak self] devices in","                \/\/ Array of available RTK Devices","                \/\/ Received value: [CBPeripheral]","                self?.currentDevice = devices.first","            }.store(in: &subscription)","    }","","    \/\/ Public methods","","    func connectToDevice() {","        guard let currentDevice else {","            print(\"Device not found\")","            return","        }","","        let logFile = createLogFile(nameDevice: currentDevice.name,","                                    fileExtension: \"jsonl\", folder: \"SupportLog\/basic\")","","        try? Vigram.Logger(url: logFile, mode: .basic)","        peripheral = Vigram.peripheral(currentDevice)","","        bluetoothService?.connect(to: currentDevice.identifier)","            .sink(receiveCompletion: { [weak self] completion in","                switch completion {","                case .finished:","                    \/\/ Connect successful","                    guard let self else { return }","                    self.peripheral?","                        .start()","                        .sink(receiveCompletion: { completion in","                            switch completion {","                            case .finished:","                                \/\/ Successful connection.","                                \/\/ You can send requests and read","                                \/\/ responses from the viDoc.","                                break","                            case .failure(let error):","                                \/\/ Error connect to Peripheral","                                print(error.localizedDescription)","                            }","                        }) { _ in }.store(in: &self.subscription)","                case .failure(let error):","                    \/\/ Error connect to CBPeripheral","                    print(error.localizedDescription)","            }","        }){ _ in }.store(in: &subscription)","    }","","    func disconnect(){","        bluetoothService?.disconnect()","        peripheral = nil","        currentDevice = nil","        startScanBluetooth()","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This completes the Setting up Bluetooth service."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The next step is "},{"type":"strong","inlineContent":[{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Work with viDoc (Peripheral)"}],"overridingTitle":"Work with viDoc (Peripheral)","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral"}]}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}]}],"type":"paragraph"},{"anchor":"More-information-about","text":"More information about","level":3,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/combine","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","overridingTitleInlineContent":[{"text":"CoreBluetooth Documentation","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"CoreBluetooth Documentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"Using Combine and Publishers"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"SDK Errors and exceptions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","overridingTitleInlineContent":[{"text":"Demo repository","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"Demo repository"}]}]}],"type":"unorderedList"},{"anchor":"Navigation","text":"Navigation","level":2,"type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"Up to Getting started with VigramSDK","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","overridingTitle":"Up to Getting started with VigramSDK"}],"type":"paragraph"},{"inlineContent":[{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"✅ STEP 1 (Import VigramSDK)","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted","overridingTitle":"✅ STEP 1 (Import VigramSDK)"}],"type":"paragraph"},{"inlineContent":[{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"✅ STEP 2 (SDK Authentication)","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSD