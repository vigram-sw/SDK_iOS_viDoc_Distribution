{"kind":"article","sections":[],"metadata":{"title":"Use Peripheral Configuration","images":[{"type":"icon","identifier":"logo.png"}],"roleHeading":"Article","role":"article","modules":[{"name":"VigramSDK"}]},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"]}],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"content":[{"level":2,"text":"","type":"heading","anchor":""},{"inlineContent":[{"text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},{"text":" and pass it to the peripheral initializer.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"]},{"inlineContent":[{"text":"Then pass the configuration to the peripheral initializer:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"]},{"inlineContent":[{"text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation used in navigation is set to 10 degrees","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellations are active","glonassActivate = true","beidouActivate = true","galileoActivate = true","qzssActivate = true","sbassActivate = true","","\/\/ NAV-DOP and NAV-PVT messages are active","navDOPActivate = true","navPVTActivate = true","","\/\/ Dynamic state mode","dynamicType = .pedestrian"]}],"kind":"content"}],"references":{"doc://com.vigramsdk/documentation/VigramSDK/PeripheralConfiguration":{"url":"\/documentation\/vigramsdk\/peripheralconfiguration","navigatorTitle":[{"text":"PeripheralConfiguration","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration","title":"PeripheralConfiguration","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PeripheralConfiguration","kind":"identifier"}],"abstract":[{"text":"Initial configuration for peripheral","type":"text"}],"type":"topic","role":"symbol"},"logo.png":{"type":"image","alt":"Vigram logo.","variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"identifier":"logo.png"},"doc://com.vigramsdk/documentation/VigramSDK":{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","title":"VigramSDK","role":"collection","url":"\/documentation\/vigramsdk","abstract":[],"images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","kind":"symbol"}}}