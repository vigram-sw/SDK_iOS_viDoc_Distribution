{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"]}],"metadata":{"images":[{"identifier":"logo.png","type":"icon"}],"roleHeading":"Article","role":"article","title":"Use Peripheral Configuration","modules":[{"name":"VigramSDK"}]},"kind":"article","primaryContentSections":[{"content":[{"text":"","anchor":"","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},{"type":"text","text":" and pass it to the peripheral initializer."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":"swift","code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then pass the configuration to the peripheral initializer:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation used in navigation is set to 10 degrees","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellations are active","glonassActivate = true","beidouActivate = true","galileoActivate = true","qzssActivate = true","sbassActivate = true","","\/\/ NAV-DOP and NAV-PVT messages are active","navDOPActivate = true","navPVTActivate = true","","\/\/ Dynamic state mode","dynamicType = .pedestrian"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://com.vigramsdk/documentation/VigramSDK/PeripheralConfiguration":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Initial configuration for peripheral"}],"url":"\/documentation\/vigramsdk\/peripheralconfiguration","title":"PeripheralConfiguration","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PeripheralConfiguration"}],"navigatorTitle":[{"kind":"identifier","text":"PeripheralConfiguration"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},"doc://com.vigramsdk/documentation/VigramSDK":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"symbol","type":"topic","abstract":[],"url":"\/documentation\/vigramsdk","title":"VigramSDK","role":"collection","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"logo.png":{"variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"identifier":"logo.png","alt":"Vigram logo.","type":"image"}}}