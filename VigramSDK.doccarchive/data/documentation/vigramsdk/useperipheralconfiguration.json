{"kind":"article","identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"","type":"heading","anchor":""},{"inlineContent":[{"type":"text","text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration","isActive":true},{"type":"text","text":" and pass it to the peripheral initializer."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":"swift","code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then pass the configuration to the peripheral initializer:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation used in navigation is set to 10 degrees","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellations are active","glonassActivate = true","beidouActivate = true","galileoActivate = true","qzssActivate = true","sbassActivate = true","","\/\/ NAV-DOP and NAV-PVT messages are active","navDOPActivate = true","navPVTActivate = true","","\/\/ Dynamic state mode","dynamicType = .pedestrian"],"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Article","role":"article","title":"Use Peripheral Configuration","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"VigramSDK"}]},"references":{"logo.png":{"variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"alt":"Vigram logo.","identifier":"logo.png","type":"image"},"doc://com.vigramsdk/documentation/VigramSDK":{"abstract":[],"title":"VigramSDK","images":[{"type":"icon","identifier":"logo.png"}],"role":"collection","url":"\/documentation\/vigramsdk","kind":"symbol","type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"doc://com.vigramsdk/documentation/VigramSDK/PeripheralConfiguration":{"abstract":[{"type":"text","text":"Initial configuration for peripheral"}],"navigatorTitle":[{"kind":"identifier","text":"PeripheralConfiguration"}],"title":"PeripheralConfiguration","role":"symbol","url":"\/documentation\/vigramsdk\/peripheralconfiguration","kind":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PeripheralConfiguration","kind":"identifier"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"}}}