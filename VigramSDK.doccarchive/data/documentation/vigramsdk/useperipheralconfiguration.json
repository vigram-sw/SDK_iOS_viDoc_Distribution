{"sections":[],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"","text":"","type":"heading"},{"inlineContent":[{"text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},{"text":" and pass it to the peripheral initializer.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":"swift","code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then pass the configuration to the peripheral initializer:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation use