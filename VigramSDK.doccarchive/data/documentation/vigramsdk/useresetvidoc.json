{"sections":[],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseResetVidoc","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useresetvidoc"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"","anchor":"","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The viDoc reset procedure returns the settings to factory defaults."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"type":"text","text":" Perform this procedure only if absolutely necessary."}]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The reset procedure takes approximately 1 minute.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the beginning of the process, all messages are interrupted."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Disconnection from all satellites occurs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the viDoc is reset, sending messages resumes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You must wait to receive the full NMEA GGA message."}]}],"style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To track the reset process, you need to use publisher"}]},{"code":["private var cancellables = Set<AnyCancellable>()","","peripheral.viDocResetState","    .sink(receiveCompletion: { completion in","        switch completion {","        case .finished:","            break \/\/ normal completion","        case .failure(let error):","            \/\/ do something with error","        }","    }) { [weak self] viDocResetState in","            switch viDocResetState {","            case let .isReseting(value):","                if value {","                    \/\/ reset in progress","                } else {","                    \/\/ reset is finished","                }","            case .failure: ","                \/\/ Error of reset viDoc","                break","            }","    }.store(in: &cancellables)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To start the reset process, you need to perform the following method:"}]},{"code":["peripheral.resetViDoc()"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","images":[{"identifier":"logo.png","type":"icon"}],"role":"article","title":"Use Reset viDoc"},"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","title":"VigramSDK","abstract":[],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","url":"\/documentation\/vigramsdk","role":"collection"},"logo.png":{"type":"image","variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"alt":"Vigram logo.","identifier":"logo.png"}}}