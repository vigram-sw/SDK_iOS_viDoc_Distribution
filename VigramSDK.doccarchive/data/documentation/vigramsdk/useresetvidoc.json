{"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"images":[{"type":"icon","identifier":"logo.png"}],"modules":[{"name":"VigramSDK"}],"role":"article","roleHeading":"Article","title":"Use Reset viDoc"},"sections":[],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseResetVidoc","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"","anchor":""},{"type":"paragraph","inlineContent":[{"text":"The viDoc reset procedure returns the settings to factory defaults.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"text":" Perform this procedure only if absolutely necessary.","type":"text"}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"The reset procedure takes approximately 1 minute.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"At the beginning of the process, all messages are interrupted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Disconnection from all satellites occurs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"After the viDoc is reset, sending messages resumes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You must wait to receive the full NMEA GGA message.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"To track the reset process, you need to use publisher","type":"text"}]},{"code":["private var cancellables = Set<AnyCancellable>()","","peripheral.viDocResetState","    .sink(receiveCompletion: { completion in","        switch completion {","        case .finished:","            break \/\/ normal completion","        case .failure(let error):","            \/\/ do something with error","        }","    }) { [weak self] viDocResetState in","            switch viDocResetState {","            case let .isReseting(value):","                if value {","                    \/\/ reset in progress","                } else {","                    \/\/ reset is finished","                }","            case .failure: ","                \/\/ Error of reset viDoc","                break","            }","    }.store(in: &cancellables)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"To start the reset process, you need to perform the following method:","type":"text"}],"type":"paragraph"},{"code":["peripheral.resetViDoc()"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/vigramsdk\/useresetvidoc"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"logo.png":{"type":"image","alt":"Vigram logo.","variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"identifier":"logo.png"},"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","role":"collection","abstract":[],"url":"\/documentation\/vigramsdk","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","title":"VigramSDK"}}}