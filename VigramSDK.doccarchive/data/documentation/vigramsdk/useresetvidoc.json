{"metadata":{"images":[{"type":"icon","identifier":"logo.png"}],"roleHeading":"Article","title":"Use Reset viDoc","modules":[{"name":"VigramSDK"}],"role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useresetvidoc"]}],"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseResetVidoc"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"text":"","type":"heading","anchor":"","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The viDoc reset procedure returns the settings to factory defaults."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"type":"text","text":" Perform this procedure only if absolutely necessary."}]},{"content":[{"inlineContent":[{"text":"The reset procedure takes approximately 1 minute.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"At the beginning of the process, all messages are interrupted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Disconnection from all satellites occurs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"After the viDoc is reset, sending messages resumes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You must wait to receive the full NMEA GGA message.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"inlineContent":[{"text":"To track the reset process, you need to use publisher","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["private var cancellables = Set<AnyCancellable>()","","peripheral.viDocResetState","    .sink(receiveCompletion: { completion in","        switch completion {","        case .finished:","            break \/\/ normal completion","        case .failure(let error):","            \/\/ do something with error","        }","    }) { [weak self] viDocResetState in","            switch viDocResetState {","            case let .isReseting(value):","                if value {","                    \/\/ reset in progress","                } else {","                    \/\/ reset is finished","                }","            case .failure: ","                \/\/ Error of reset viDoc","                break","            }","    }.store(in: &cancellables)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"To start the reset process, you need to perform the following method:"}],"type":"paragraph"},{"syntax":"swift","code":["peripheral.resetViDoc()"],"type":"codeListing"}],"kind":"content"}],"references":{"logo.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"type":"image","identifier":"logo.png","alt":"Vigram logo."},"doc://com.vigramsdk/documentation/VigramSDK":{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","title":"VigramSDK","role":"collection","url":"\/documentation\/vigramsdk","abstract":[],"images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","kind":"symbol"}}}