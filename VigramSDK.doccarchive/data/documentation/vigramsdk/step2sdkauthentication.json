{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/step2sdkauthentication"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token."}]},{"type":"paragraph","inlineContent":[{"text":"Authentication check is performed when calling any VigramSDK service:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig12.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the authentication procedure is not completed, access to the SDK functions will not be available"}]},{"type":"paragraph","inlineContent":[{"text":"First, to use the SDK, you must be authenticated.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","isActive":true},{"type":"text","text":" object to check your token."}]},{"type":"codeListing","syntax":"swift","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Return value:"}]},{"type":"text","text":" Result<Bool, AuthenticationError>"}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","type":"reference"}],"type":"paragraph"},{"text":"","anchor":"","level":3,"type":"heading"},{"inlineContent":[{"text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the authentication procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"type":"strong","inlineContent":[{"isActive":true,"overridingTitle":"change the configuration parameters.","overridingTitleInlineContent":[{"text":"change the configuration parameters.","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters"}]}],"type":"paragraph"},{"type":"paragraph","inli