{"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token."}]},{"type":"paragraph","inlineContent":[{"text":"Authentication check is performed when calling any VigramSDK service:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"fig12.png"}]},{"type":"paragraph","inlineContent":[{"text":"If the authentication procedure is not completed, access to the SDK functions will not be available","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, to use the SDK, you must be authenticated."},{"type":"text","text":" "},{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","isActive":true},{"type":"text","text":" object to check your token."}]},{"type":"codeListing","syntax":"swift","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Return value:"}],"type":"strong"},{"type":"text","text":" Result<Bool, AuthenticationError>"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Throw error:"}],"type":"strong"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError"}]},{"text":"","level":3,"type":"heading","anchor":""},{"type":"paragraph","inlineContent":[{"text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline).","type":"text"}]},{"inlineContent":[{"text":"This completes the authentication procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The next step is "},{"type":"strong","inlineContent":[{"isActive":true,"overridingTitle":"change the configuration parameters.","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters","overridingTitleInlineContent":[{"text":"change the configuration parameters.","type":"text"}],"type":"reference"}]}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","type":"reference"}]}]},{"type":"heading","level":3,"text":"More information about","anchor":"More-information-about"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/combine","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitle":"Using Combine and Publishers","overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","isActive":true,"overridingTitle":"SDK Errors and exceptions","type":"reference","overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","isActive":true,"overridingTitle":"Demo repository","overridingTitleInlineContent":[{"text":"Demo repository","type":"text"}],"type":"reference"}]}]}]},{"type":"heading","level":2,"text":"Navigation","anchor":"Navigation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","isActive":true,"overridingTitle":"Up to Getting started with VigramSDK","overridingTitleInlineContent":[{"text":"Up to Getting started with VigramSDK","type":"text"}]}]},{"type":"paragraph","in