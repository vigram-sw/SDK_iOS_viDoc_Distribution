{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"VigramSDK"}],"role":"article","images":[{"type":"icon","identifier":"logo.png"}],"title":"SDK Authentication","roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Authentication check is performed when calling any VigramSDK service:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig12.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the authentication procedure is not completed, access to the SDK functions will not be available"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"First, to use the SDK, you must be authenticated."},{"text":" ","type":"text"},{"type":"text","text":"Creates a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication"},{"type":"text","text":" object to check your token."}],"type":"paragraph"},{"code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Return value:","type":"text"}]},{"text":" Result<Bool, AuthenticationError>","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","type":"reference","isActive":true}],"type":"paragraph"},{"anchor":"","text":"","type":"heading","level":3},{"inlineContent":[{"text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the authentication procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"type":"strong","inlineContent":[{"overridingTitle":"change the configuration parameters.","type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"change the configuration parameters."}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters"}]}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}]}],"type":"paragraph"},{"anchor":"More-information-about","text":"More information about","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/combine"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"Using Combine and Publishers","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitleInlineContent":[{"type":"text","text":"Using Combine and Publishers"}],"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"SDK Errors and exceptions","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}],"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","type":"reference","isActive":true,"overridingTitle":"Demo repository","overridingTitleInlineContent":[{"type":"text","text":"Demo repository"}]}]}]}],"type":"unorderedList"},{"anchor":"Navigation","text":"Navigation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"Up to Getting started with Vigram