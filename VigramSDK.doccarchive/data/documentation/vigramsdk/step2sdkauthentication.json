{"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token."}],"type":"paragraph"},{"inlineContent":[{"text":"Authentication check is performed when calling any VigramSDK service:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig12.png"}],"type":"paragraph"},{"inlineContent":[{"text":"If the authentication procedure is not completed, access to the SDK functions will not be available","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"First, to use the SDK, you must be authenticated."},{"type":"text","text":" "},{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","isActive":true},{"type":"text","text":" object to check your token."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Return value:"}]},{"type":"text","text":" Result<Bool, AuthenticationError>"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Throw error:"}],"type":"strong"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","type":"reference","isActive":true}],"type":"paragraph"},{"type":"heading","level":3,"text":"","anchor":""},{"inlineContent":[{"text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This completes the authentication procedure."}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"type":"strong","inlineContent":[{"type":"reference","overridingTitleInlineContent":[{"text":"change the configuration parameters.","type":"text"}],"overridingTitle":"change the configuration parameters.","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters"}]}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo