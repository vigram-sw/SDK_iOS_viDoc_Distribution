{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Authentication check is performed when calling any VigramSDK service:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig12.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the authentication procedure is not completed, access to the SDK functions will not be available"}],"type":"paragraph"},{"inlineContent":[{"text":"First, to use the SDK, you must be authenticated.","type":"text"},{"text":" ","type":"text"},{"text":"Creates a ","type":"text"},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","isActive":true,"type":"reference"},{"text":" object to check your token.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"]},{"inlineContent":[{"inlineContent":[{"text":"Return value:","type":"text"}],"type":"strong"},{"text":" Result<Bool, AuthenticationError>","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Throw error:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError"}],"type":"paragraph"},{"text":"","type":"heading","level":3,"anchor":""},{"inlineContent":[{"text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the authentication procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"change the configuration parameters."}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters","isActive":true,"overridingTitle":"change the configuration parameters.","type":"reference"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{