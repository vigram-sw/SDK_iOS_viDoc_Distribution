{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"},"metadata":{"images":[{"type":"icon","identifier":"logo.png"}],"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","role":"article","title":"SDK Authentication"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Authentication check is performed when calling any VigramSDK service:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig12.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the authentication procedure is not completed, access to the SDK functions will not be available"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"First, to use the SDK, you must be authenticated."},{"type":"text","text":" "},{"type":"text","text":"Creates a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication"},{"type":"text","text":" object to check your token."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Return value:","type":"text"}]},{"type":"text","text":" Result<Bool, AuthenticationError>"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError"}],"type":"paragraph"},{"level":3,"type":"heading","text":"","anchor":""},{"inlineContent":[{"type":"text","text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This completes the authentication procedure."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The next step is "},{"type":"strong","inlineContent":[{"isActive":true,"type":"reference","overridingTitle":"change the configuration parameters.","overridingTitleInlineContent":[{"type":"text","tex