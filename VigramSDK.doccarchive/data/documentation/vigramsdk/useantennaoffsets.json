device components in relation to the antenna’s position for various devices."}],"type":"paragraph"},{"inlineContent":[{"text":"Assuming the device is in portrait mode.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"X-Offset: (-) Left -> Right (+) of the device."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Y-Offset: (-) Bottom -> Top (+) of the device."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Z-Offset: (-) Back -> Front (+) of the device."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"An example of offsets for iPhone 12 Pro, 12 Pro Max is presented below"}],"type":"paragraph"},{"inlineContent":[{"identifier":"15.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"16.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example of using offsets in "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","isActive":true,"overridingTitle":"Single point measurements","overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}]},{"type":"text","text":" with Laser"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Bottom laser selected","let typeOfLaser: LaserConfiguration.Position = .bottom ","","\/\/ Laser measurement mode - fast","let laserShotMode: LaserConfiguration.ShotMode = .fast ","","\/\/ Measurement duration (in seconds). ","\/\/ For viDoc protocol version < 2, the measurement duration","\/\/ must be in the range [5...60] seconds.","\/\/","\/\/ For protocol >= 2, any value can be specified. If 0 is ","\/\/ specified, the measurement will continue ","\/\/ indefinitely.","\/\/ ","\/\/ More details in section №8 (Using Single point measurements)","let duration: Double = 30","","\/\/ Creating a laser configuration. ","\/\/ The laser configuration. Keep in mind, that you will not receive ","\/\/ further environment data values after the laser duration has passed.","let laserConfig = LaserConfiguration.init(shotMode: laserShotMode, ","                                          position: typeOfLaser, ","                                          duration: duration)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.Laser.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ UseDeviceMotion - This attribute specifies whether to incorporate ","\/\/ the device motion into the calculation of the corrected coordinate. ","\/\/ This allows to not only correct coordinates by strictly subtracting ","\/\/ the laser distance measurement from the measured antenna position,","\/\/ but rather enables diagonally held laser measurements as well.","let method = ","    CoordinateCorrection.Method.laser(configuration: laserConfig, ","                                      antennaOffset: offset,","                                      useDeviceMotion: true)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  laserService: laserService!,","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .failure(let error):","            \/\/ Do something with error","        case .finished:","            break","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"]},{"text":"More information about","level":3,"type":"heading","anchor":"More-information-about"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"Peripheral","type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Peripheral"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"GPSService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","overridingTitleInlineContent":[{"type":"text","text":"GPSService"}],"type":"reference","isActive":true}]}]},{"content":[{"inlineContent":[{"isActive":true,"overridingTitle":"LaserService","overridingTitleInlineContent":[{"text":"LaserService","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","overridingTitle":"Single point measurements","overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}]}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note: Offsets have a data type "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3","isActive":true}]},{"type":"paragraph","inlineContent":[{"text":"You can set your own custom offsets","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let yourCustomOffset = SIMD3(x: 4.4, y: -1.6, z: 2) \/ 100"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example of using offsets in "},{"isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}],"type":"reference","overridingTitle":"Single point measurements","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint"},{"type":"text","text":" without Laser"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ The distance from the antenna to the ground to subtract from the ","\/\/ antenna’s coordinate’s altitude.","let distanceToGround = Double(distanceToGround)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.SPC.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ When using the constant height coordinate correction,","\/\/ the correctedCoordinate property of EnvironmentData will reflect ","\/\/ the position of the antenna with an altitude subtracted by the ","\/\/ constant value.","let method = ","    CoordinateCorrection.Method","        .constant(distanceFromAntennaToGround: antennaDistanceToGround)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","          