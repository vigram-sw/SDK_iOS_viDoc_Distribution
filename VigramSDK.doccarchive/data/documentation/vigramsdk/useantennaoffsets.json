{"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseAntennaOffsets","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"","type":"heading","text":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"Antenna offsets are the offset of the camera relative to the antenna attached to viDoc for a specific device."},{"type":"text","text":" "},{"type":"text","text":"Depending on the device used, we return the specific camera offset that works best."}]},{"anchor":"","type":"heading","level":2,"text":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following offset options exist:"}]},{"syntax":"swift","code":["public enum AntennaOffset {","    case Camera \/\/ This type of offset will be removed in future versions ","                \/\/ of the SDK.","    case SPC \/\/ For viDoc with SPC case","    case SPCPlus \/\/ For viDoc with SPC+ case","    case SPCPlusLight \/\/ For viDoc Light with SPC+ case","    case Laser \/\/ The laser offset in relation to the antenna's position","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constants used in measurements:"}]},{"syntax":"swift","code":["\/\/ The middle antenna height (by default).","\/\/","\/\/ Distance from the bottom of the antenna to the center (cm).","\/\/","\/\/ Available from SDK: 0.5.3","Configuration.middleAntenna: Double = 3.57","","","\/\/ The device height (by default).","\/\/","\/\/ Distance from the bottom of the device to the center (cm).","\/\/","\/\/ Available from SDK: 0.5.3","Configuration.deviceHeight: Double = 15.2"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The offset of different device components in relation to the antenna’s position for various devices."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Assuming the device is in portrait mode."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"X-Offset: (-) Left -> Right (+) of the device."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Y-Offset: (-) Bottom -> Top (+) of the device."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Z-Offset: (-) Back -> Front (+) of the device."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example of offsets for iPhone 12 Pro, 12 Pro Max is presented below"}]},{"type":"paragraph","inlineContent":[{"identifier":"15.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"16.png"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example of using offsets in "},{"overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}],"type":"reference","isActive":true,"overridingTitle":"Single point measurements","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint"},{"type":"text","text":" with Laser"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Bottom laser selected","let typeOfLaser: LaserConfiguration.Position = .bottom ","","\/\/ Laser measurement mode - fast","let laserShotMode: LaserConfiguration.ShotMode = .fast ","","\/\/ Measurement duration (in seconds). ","\/\/ For viDoc protocol version < 2, the measurement duration","\/\/ must be in the range [5...60] seconds.","\/\/","\/\/ For protocol >= 2, any value can be specified. If 0 is ","\/\/ specified, the measurement will continue ","\/\/ indefinitely.","\/\/ ","\/\/ More details in section №8 (Using Single point measurements)","let duration: Double = 30","","\/\/ Creating a laser configuration. ","\/\/ The laser configuration. Keep in mind, that you will not receive ","\/\/ further environment data values after the laser duration has passed.","let laserConfig = LaserConfiguration.init(shotMode: laserShotMode, ","                                          position: typeOfLaser, ","                                          duration: duration)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.Laser.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ UseDeviceMotion - This attribute specifies whether to incorporate ","\/\/ the device motion into the calculation of the corrected coordinate. ","\/\/ This allows to not only correct coordinates by strictly subtracting ","\/\/ the laser distance measurement from the measured antenna position,","\/\/ but rather enables diagonally held laser measurements as well.","let method = ","    CoordinateCorrection.Method.laser(configuration: laserConfig, ","                                      antennaOffset: offset,","                                      useDeviceMotion: true)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  laserService: laserService!,","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .failure(let error):","            \/\/ Do something with error","        case .finished:","            break","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"]},{"type":"heading","text":"More information about","anchor":"More-information-about","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"Peripheral"}],"type":"reference","isActive":true,"overridingTitle":"Peripheral","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"GPSService"}],"type":"reference","isActive":true,"overridingTitle":"GPSService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"LaserService"}],"type":"reference","isActive":true,"overridingTitle":"LaserService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}],"type":"reference","isActive":true,"overridingTitle":"Single point measurements","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note: Offsets have a data type "},{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3","type":"reference","isActive":true}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set your own custom offsets"}]},{"type":"codeListing","code":["let yourCustomOffset = SIMD3(x: 4.4, y: -1.6, z: 2) \/ 100"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Example of using offsets in "},{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Single point measurements"}],"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","overridingTitle":"Single point measurements"},{"type":"text","text":" without Laser"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ The distance from the antenna to the ground to subtract from the ","\/\/ antenna’s coordinate’s altitude.","let distanceToGround = Double(distanceToGround)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.SPC.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ When using the constant height coordinate correction,","\/\/ the correctedCoordinate property of EnvironmentData will reflect ","\/\/ the position of the antenna with an altitude subtracted by the ","\/\/ constant value.","let method = ","    CoordinateCorrection.Method","        .constant(distanceFromAntennaToGround: antennaDistanceToGround)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .failure(let error):","            \/\/ Do something with error","        case .finished:","            break","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"VigramSDK"}],"role":"article","roleHeading":"Article","images":[{"identifier":"logo.png","type":"icon"}],"title":"Use Antenna Offsets"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useantennaoffsets"]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK/Step7LaserService":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"article","type":"topic","abstract":[],"url":"\/documentation\/vigramsdk\/step7laserservice","title":"Using Laser service","role":"article","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"},"doc://com.vigramsdk/documentation/VigramSDK":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"symbol","type":"topic","abstract":[],"url":"\/documentation\/vigramsdk","title":"VigramSDK","role":"collection","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"doc://com.vigramsdk/documentation/VigramSDK/Step6UsingNTRIP":{"abstract":[],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","kind":"article","images":[{"type":"icon","identifier":"logo.png"}],"role":"article","title":"Using NTRIP correction","type":"topic","url":"\/documentation\/vigramsdk\/step6usingntrip"},"15.png":{"type":"image","identifier":"15.png","alt":"Fig.1","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/15.png"}]},"https://developer.apple.com/documentation/swift/simd3":{"title":"SIMD3","titleInlineContent":[{"text":"SIMD3","type":"text"}],"type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3","url":"https:\/\/developer.apple.com\/documentation\/swift\/simd3"},"doc://com.vigramsdk/documentation/VigramSDK/Step5WorkWithPeripheral":{"url":"\/doc