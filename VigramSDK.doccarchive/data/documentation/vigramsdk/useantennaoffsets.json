{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"roleHeading":"Article","title":"Use Antenna Offsets","images":[{"type":"icon","identifier":"logo.png"}],"role":"article","modules":[{"name":"VigramSDK"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseAntennaOffsets"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"","text":"","level":2},{"type":"paragraph","inlineContent":[{"text":"Antenna offsets are the offset of the camera relative to the antenna attached to viDoc for a specific device.","type":"text"},{"text":" ","type":"text"},{"text":"Depending on the device used, we return the specific camera offset that works best.","type":"text"}]},{"type":"heading","anchor":"","text":"","level":2},{"type":"paragraph","inlineContent":[{"text":"The following offset options exist:","type":"text"}]},{"type":"codeListing","code":["public enum AntennaOffset {","    case Camera \/\/ This type of offset will be removed in future versions ","                \/\/ of the SDK.","    case SPC \/\/ For viDoc with SPC case","    case SPCPlus \/\/ For viDoc with SPC+ case","    case SPCPlusLight \/\/ For viDoc Light with SPC+ case","    case Laser \/\/ The laser offset in relation to the antenna's position","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Constants used in measurements:","type":"text"}]},{"type":"codeListing","code":["\/\/ The middle antenna height (by default).","\/\/","\/\/ Distance from the bottom of the antenna to the center (cm).","\/\/","\/\/ Available from SDK: 0.5.3","Configuration.middleAntenna: Double = 3.57","","","\/\/ The device height (by default).","\/\/","\/\/ Distance from the bottom of the device to the center (cm).","\/\/","\/\/ Available from SDK: 0.5.3","Configuration.deviceHeight: Double = 15.2"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The offset of different device components in relation to the antenna’s position for various devices.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Assuming the device is in portrait mode.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"X-Offset: (-) Left -> Right (+) of the device."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Y-Offset: (-) Bottom -> Top (+) of the device."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Z-Offset: (-) Back -> Front (+) of the device."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"An example of offsets for iPhone 12 Pro, 12 Pro Max is presented below","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"15.png"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"16.png"}]},{"type":"paragraph","inlineContent":[{"text":"Example of using offsets in ","type":"text"},{"overridingTitle":"Single point measurements","overridingTitleInlineContent":[{"text":"Single point measurements","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","isActive":true},{"text":" with Laser","type":"text"}]},{"type":"codeListing","code":["\/\/ Bottom laser selected","let typeOfLaser: LaserConfiguration.Position = .bottom ","","\/\/ Laser measurement mode - fast","let laserShotMode: LaserConfiguration.ShotMode = .fast ","","\/\/ Measurement duration (in seconds). ","\/\/ For viDoc protocol version < 2, the measurement duration","\/\/ must be in the range [5...60] seconds.","\/\/","\/\/ For protocol >= 2, any value can be specified. If 0 is ","\/\/ specified, the measurement will continue ","\/\/ indefinitely.","\/\/ ","\/\/ More details in section №8 (Using Single point measurements)","let duration: Double = 30","","\/\/ Creating a laser configuration. ","\/\/ The laser configuration. Keep in mind, that you will not receive ","\/\/ further environment data values after the laser duration has passed.","let laserConfig = LaserConfiguration.init(shotMode: laserShotMode, ","                                          position: typeOfLaser, ","                                          duration: duration)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.Laser.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ UseDeviceMotion - This attribute specifies whether to incorporate ","\/\/ the device motion into the calculation of the corrected coordinate. ","\/\/ This allows to not only correct coordinates by strictly subtracting ","\/\/ the laser distance measurement from the measured antenna position,","\/\/ but rather enables diagonally held laser measurements as well.","let method = ","    CoordinateCorrection.Method.laser(configuration: laserConfig, ","                                      antennaOffset: offset,","                                      useDeviceMotion: true)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  laserService: laserService!,","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .failure(let error):","            \/\/ Do something with error","        case .finished:","            break","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"],"syntax":"swift"},{"type":"heading","anchor":"More-information-about","text":"More information about","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral","type":"reference","isActive":true,"overridingTitle":"Peripheral","overridingTitleInlineContent":[{"text":"Peripheral","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","type":"reference","isActive":true,"overridingTitle":"GPSService","overridingTitleInlineContent":[{"text":"GPSService","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService","type":"reference","isActive":true,"overridingTitle":"LaserService","overridingTitleInlineContent":[{"text":"LaserService","type":"text"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","type":"reference","isActive":true,"overridingTitle":"Single point measurements","overridingTitleInlineContent":[{"text":"Single point measurements","type":"text"}]}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Note: Offsets have a data type ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3","isActive":true}]},{"type":"paragraph","inlineContent":[{"text":"You can set your own custom offsets","type":"text"}]},{"type":"codeListing","code":["let yourCustomOffset = SIMD3(x: 4.4, y: -1.6, z: 2) \/ 100"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Example of using offsets in ","type":"text"},{"overridingTitle":"Single point measurements","overridingTitleInlineContent":[{"text":"Single point measurements","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","isActive":true},{"text":" without Laser","type":"text"}]},{"type":"codeListing","code":["\/\/ The distance from the antenna to the ground to subtract from the ","\/\/ antenna’s coordinate’s altitude.","let distanceToGround = Double(distanceToGround)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.SPC.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ When using the constant height coordinate correction,","\/\/ the correctedCoordinate property of EnvironmentData will reflect ","\/\/ the position of the antenna with an altitude subtracted by the ","\/\/ constant value.","let method = ","    CoordinateCorrection.Method","        .constant(distanceFromAntennaToGround: antennaDistanceToGround)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .failure(let error):","            \/\/ Do something with error","        case .finished:","            break","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"],"syntax":"swift"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useantennaoffsets"]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK/Step6UsingNTRIP":{"url":"\/documentation\/vigramsdk\/step6usingntrip","role":"article","kind":"article","abstract":[],"images":[{"type":"icon","identifier":"logo.png"}],"title":"Using NTRIP correction","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","type":"topic"},"15.png":{"alt":"Fig.1","identifier":"15.png","type":"image","variants":[{"url":"\/images\/com.vigramsdk\/15.png","traits":["1x","light"]}]},"doc://com.vigramsdk/documentation/VigramSDK/Step5WorkWithPeripheral":{"title":"Work with viDoc (Peripheral)","type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral","url":"\/documentation\/vigramsdk\/step5workwithperipheral","kind":"article","role":"article","abstract":[],"images":[{"identifier":"logo.png","type":"icon"}]},"logo.png":{"alt":"Vigram logo.","identifier":"logo.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}]},"16.png":{"alt":"Fig.2","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/16.png"}],"type":"image","identifier":"16.png"},"doc://com.vigramsdk/documentation/VigramSDK/Step8SinglePoint":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"article","abstract":[],"role":"article","title":"Using Single point measurements","type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","url":"\/documentation\/v