{"primaryContentSections":[{"content":[{"text":"","type":"heading","level":2,"anchor":""},{"inlineContent":[{"type":"text","text":"This section provides a detailed description of errors that may occur while using the SDK."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","isActive":true}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"These errors can be received when using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum AuthenticationError: Swift.Error {","","    \/\/ Error authentication - bundle is not exist","    case bundleNotExist(String)","","    \/\/ Error authentication - token is not exist","    case tokenNotExist(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ bundle and token is incorrect)","    case wrongTokenAndBundle(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ (bundle, token or platformId is incorrect)","    case wrongCombination(String)","","    \/\/ Authentication is failure - Other error received ","    \/\/ from server","    case failure(String)","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError","isActive":true,"type":"reference"}]}]}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError"},{"type":"text","text":" combines different failure events that can be emitted on sending data to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Peripheral"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum PeripheralError: Swift.Error {","","    \/\/ The peripheral does not have a characteristic to write to.","    \/\/ Note: This error might be thrown, when we did not yet gather ","    \/\/ enough characteristics of the peripheral.","    case characteristicNotFound","","    \/\/ A send request is aborted, since the peripheral has already ","    \/\/ been deallocated.","    \/\/ Since VigramSDK is waiting for all previous messages to be ","    \/\/ sent before attempting","    \/\/ to send a message, it might already be deallocated when trying ","    \/\/ to send a message.","    case alreadyDeallocated","","    \/\/ Laser measurements not available in PPK mode","    case laserNotAvailableInPPK","","    \/\/ BLE write timeout exceeded.","    case writeTimeOut","","    \/\/ The configuration of the peripheral failed unexpectedly.","    case configurationFailed","    ","    \/\/ This method is not supported in current software version ","    \/\/ of the RTK device","    case requestIsNotSupported(String)","    ","    \/\/ This method is not available in this case","    case accessDenied(String)","    ","    \/\/ The current RTK device is incompatible in this SDK version","    case deviceNumberIsIncompatible","    ","    \/\/ The current software of the connected RTK device is ","    \/\/ incompatible in this SDK version","    case deviceSoftwareIsIncompatible","    ","    \/\/ Is not possible to perform the request. Device is configuring","    \/\/ in this time.","    case deviceIsBusy(String)","","    \/\/ The current version of SDK is outdated","    case sdkIsOutdated","","    \/\/ The verification of SDK is failure","    case verificationFailure(String)","","    \/\/ The unknown error","    case unknownError(String)","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError","isActive":true,"type":"reference"}]}]}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError"},{"type":"text","text":" lists different errors that can be propagated by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothService"},{"type":"text","text":" implementations."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum BluetoothServiceError: Error {","","    \/\/ The device to connect to cannot be found, since it is","    \/\/ (possibly no longer) available.","    case notAvailable(UUID)","","    \/\/ Connecting to a device failed unexplicably.","    case notConnected(UUID)","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError","isActive":true,"type":"reference"}]}]}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError"},{"type":"text","text":" contains custom failure events when connecting to Ntrip services."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" It is not ensured that calls to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripService"},{"type":"text","text":" can only result in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError"},{"type":"text","text":" events."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum NtripServiceError: Swift.Error {","","    \/\/ Mountpoints could not be decoded from the received data.","    case mountPointDecodingFailed","","    \/\/ Creating the URL to connect to Ntrip endpoints did not succeed.","    case couldNotCreateURL(NtripConnectionInformation, ","                           mountPoint: String?)","","    \/\/ We could not create an Ntrip task due to unexplicable ","    \/\/ circumstances.","    \/\/ Note: This error should never be thrown.","    case couldNotCreateTask","","    \/\/ Adding authentication to a URLRequest did not succeed.","    case couldNotAddAuthentication(URLRequest, username: String, ","                                   password: String)","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError"}],"type":"paragraph"}]}]},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError","type":"reference"},{"text":" lists different errors that can be emitted by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTask","type":"reference"},{"text":" implementations.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum NtripTaskError: Swift.Error {","","    \/\/ Creating the Ntrip network request failed.","    case couldNotCreateRequest","","    \/\/ Failed due to no data","    case noData","","    \/\/ Ntrip connection information (domain, port, or cridential) ","    \/\/ is incorrect","    case incorrectNCI","","    \/\/ Other error, received from RTCM message","    case failed(String)","","    \/\/ HTTP response error, received from server","    case httpResponceError(String)","","    \/\/ Server is not responding","    case serverIsNotResponce","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","isActive":true,"type":"reference"}]}]}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError"},{"type":"text","text":" are thrown, when due to the filtering phase of single point recordings there is not enough valid data to create a singlePoint. To investigate possible issues with the measurement, have a look at the provided associated data."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum SinglePointRecordingError: Error, Hashable {","","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/","\/\/ Available in SDK ver. 1.0.3","case nonValidData","","\/\/ This method is not supported in current software version of the RTK device","\/\/","\/\/ Available in SDK ver. 1.0.3","case requestIsNotSupported(String)","","\/\/ The correction method used has incorrect settings","\/\/ Most likely the CoordinateCorrectionMethod settings ","\/\/ were not selected and passed to the write method correctly","\/\/","\/\/ Available in SDK ver. 1.0.3","case incorrectCoordinateCorrectionMethod(String)","","\/\/ Running measurement process not found","\/\/","\/\/ Available in SDK ver. 1.0.3","case noRunningMeasurementMethod","","\/\/ The value of horizontal accuracy is too high","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case horizontalAccuracyIsTooHigh","","\/\/ The value of vertical accuracy is too high","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case verticalAccuracyIsTooHigh","","\/\/ The value of altitude difference is too high","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/","\/\/ Available in SDK ver. 1.0.3","case altitudeDifferenceIsTooHigh","","\/\/ The laser measurements are of bad quality","\/\/","\/\/ This means that most of the laser measurements were of bad ","\/\/ quality or incorrect.","\/\/","\/\/ Available in SDK ver. 1.0.3","case laserMeasurementsIsBadQuality","","\/\/ The measurement cancelled by user.","case measurementCancelled","","\/\/ Deprecated!","\/\/","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/ Most of the measured data have low accuracy.","\/\/ e.g. One or more conditions are not met","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy,","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/ The returned RAW value of this error is the received measurements.","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case badMeasurement([EnvironmentData])","","\/\/ Deprecated!","\/\/","\/\/ The measurement failure.","\/\/ In most cases this error is not returned. ","\/\/ If you get it, check if you passed the correct ","\/\/ CoordinateCorrection.Method to the SinglePointRecordingService ","\/\/ measurement procedure (record or startMeasurements).","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case measurementFailure","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/sdkerrorsandexceptions"]}],"metadata":{"images":[{"type":"icon","identifier":"logo.png"}],"role":"article","modules":[{"name":"VigramSDK"}],"title":"SDK Errors and exceptions","roleHeading":"Article"},"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"references":{"doc://com.vigramsdk/documentation/VigramSDK/NtripTaskError":{"url":"\/documentation\/vigramsdk\/ntriptaskerror","title":"NtripTaskError","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"NtripTaskError"}],"abstract":[{"text":"NtripTaskError lists different errors that can be emitted by ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/Vigra