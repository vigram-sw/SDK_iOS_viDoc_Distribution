{"metadata":{"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","title":"SDK Errors and exceptions","role":"article","images":[{"type":"icon","identifier":"logo.png"}]},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"type":"heading","anchor":"","level":2,"text":""},{"inlineContent":[{"type":"text","text":"This section provides a detailed description of errors that may occur while using the SDK."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","type":"reference","isActive":true}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"These errors can be received when using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication"}],"type":"paragraph"},{"code":["public enum AuthenticationError: Swift.Error {","","    \/\/ Error authentication - bundle is not exist","    case bundleNotExist(String)","","    \/\/ Error authentication - token is not exist","    case tokenNotExist(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ bundle and token is incorrect)","    case wrongTokenAndBundle(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ (bundle, token or platformId is incorrect)","    case wrongCombination(String)","","    \/\/ Authentication is failure - Other error received ","    \/\/ from server","    case failure(String)","}"],"type":"codeListing","syntax":"swift"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError","type":"reference","isActive":true},{"type":"text","text":" combines different failure events that can be emitted on sending data to a "},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Peripheral","type":"reference","isActive":true}],"type":"paragraph"},{"syntax":"swift","code":["public enum PeripheralError: Swift.Error {","","    \/\/ The peripheral does not have a characteristic to write to.","    \/\/ Note: This error might be thrown, when we did not yet gather ","    \/\/ enough characteristics of the peripheral.","    case characteristicNotFound","","    \/\/ A send request is aborted, since the peripheral has already ","    \/\/ been deallocated.","    \/\/ Since VigramSDK is waiting for all previous messages to be ","    \/\/ sent before attempting","    \/\/ to send a message, it might already be deallocated when trying ","    \/\/ to send a message.","    case alreadyDeallocated","","    \/\/ Laser measurements not available in PPK mode","    case laserNotAvailableInPPK","","    \/\/ BLE write timeout exceeded.","    case writeTimeOut","","    \/\/ The configuration of the peripheral failed unexpectedly.","    case configurationFailed","    ","    \/\/ This method is not supported in current software version ","    \/\/ of the RTK device","    case requestIsNotSupported(String)","    ","    \/\/ This method is not available in this case","    case accessDenied(String)","    ","    \/\/ The current RTK device is incompatible in this SDK version","    case deviceNumberIsIncompatible","    ","    \/\/ The current software of the connected RTK device is ","    \/\/ incompatible in this SDK version","    case deviceSoftwareIsIncompatible","    ","    \/\/ Is not possible to perform the request. Device is configuring","    \/\/ in this time.","    case deviceIsBusy(String)","","    \/\/ The current version of SDK is outdated","    case sdkIsOutdated","","    \/\/ The verification of SDK is failure","    case verificationFailure(String)","","    \/\/ The unknown error","    case unknownError(String)","}"],"type":"codeListing"},{"items":[