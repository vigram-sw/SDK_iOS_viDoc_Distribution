{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions"},"metadata":{"title":"SDK Errors and exceptions","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","role":"article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"level":2,"text":"","anchor":"","type":"heading"},{"inlineContent":[{"text":"This section provides a detailed description of errors that may occur while using the SDK.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError","isActive":true}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"These errors can be received when using ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","type":"reference"}],"type":"paragraph"},{"code":["public enum AuthenticationError: Swift.Error {","","    \/\/ Error authentication - bundle is not exist","    case bundleNotExist(String)","","    \/\/ Error authentication - token is not exist","    case tokenNotExist(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ bundle and token is incorrect)","    case wrongTokenAndBundle(String)","","    \/\/ Error authentication - wrong combination ","    \/\/ (bundle, token or platformId is incorrect)","    case wrongCombination(String)","","    \/\/ Authentication is failure - Other error received ","    \/\/ from server","    case failure(String)","}"],"syntax":"swift","type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError","type":"reference","isActive":true}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralError","isActive":true},{"text":" combines different failure events that can be emitted on sending data to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Peripheral"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["public enum PeripheralError: Swift.Error {","","    \/\/ The peripheral does not have a characteristic to write to.","    \/\/ Note: This error might be thrown, when we did not yet gather ","    \/\/ enough characteristics of the peripheral.","    case characteristicNotFound","","    \/\/ A send request is aborted, since the peripheral has already ","    \/\/ been deallocated.","    \/\/ Since VigramSDK is waiting for all previous messages to be ","    \/\/ sent before attempting","    \/\/ to send a message, it might already be deallocated when trying ","    \/\/ to send a message.","    case alreadyDeallocated","","    \/\/ Laser measurements not available in PPK mode","    case laserNotAvailableInPPK","","    \/\/ BLE write timeout exceeded.","    case writeTimeOut","","    \/\/ The configuration of the peripheral failed unexpectedly.","    case configurationFailed","    ","    \/\/ This method is not supported in current software version ","    \/\/ of the RTK device","    case requestIsNotSupported(String)","    ","    \/\/ This method is not available in this case","    case accessDenied(String)","    ","    \/\/ The current RTK device is incompatible in this SDK version","    case deviceNumberIsIncompatible","    ","    \/\/ The current software of the connected RTK device is ","    \/\/ incompatible in this SDK version","    case deviceSoftwareIsIncompatible","    ","    \/\/ Is not possible to perform the request. Device is configuring","    \/\/ in this time.","    case deviceIsBusy(String)","","    \/\/ The current version of SDK is outdated","    case sdkIsOutdated","","    \/\/ The verification of SDK is failure","    case verificationFailure(String)","","    \/\/ The unknown error","    case unknownError(String)","}"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError","type":"reference"}]}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError","type":"reference","isActive":true},{"type":"text","text":" lists different errors that can be propagated by "},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothService","type":"reference","isActive":true},{"text":" implementations.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["public enum BluetoothServiceError: Error {","","    \/\/ The device to connect to cannot be found, since it is","    \/\/ (possibly no longer) available.","    case notAvailable(UUID)","","    \/\/ Connecting to a device failed unexplicably.","    case notConnected(UUID)","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError","type":"reference","isActive":true}],"type":"paragraph"}]}]},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError","type":"reference","isActive":true},{"type":"text","text":" contains custom failure events when connecting to Ntrip services."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"text":" It is not ensured that calls to ","type":"text"},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripService","type":"reference","isActive":true},{"text":" can only result in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripServiceError","type":"reference"},{"text":" events.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["public enum NtripServiceError: Swift.Error {","","    \/\/ Mountpoints could not be decoded from the received data.","    case mountPointDecodingFailed","","    \/\/ Creating the URL to connect to Ntrip endpoints did not succeed.","    case couldNotCreateURL(NtripConnectionInformation, ","                           mountPoint: String?)","","    \/\/ We could not create an Ntrip task due to unexplicable ","    \/\/ circumstances.","    \/\/ Note: This error should never be thrown.","    case couldNotCreateTask","","    \/\/ Adding authentication to a URLRequest did not succeed.","    case couldNotAddAuthentication(URLRequest, username: String, ","                                   password: String)","}"]},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError","isActive":true}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError","isActive":true},{"type":"text","text":" lists different errors that can be emitted by "},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTask","isActive":true},{"type":"text","text":" implementations."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["public enum NtripTaskError: Swift.Error {","","    \/\/ Creating the Ntrip network request failed.","    case couldNotCreateRequest","","    \/\/ Failed due to no data","    case noData","","    \/\/ Ntrip connection information (domain, port, or cridential) ","    \/\/ is incorrect","    case incorrectNCI","","    \/\/ Other error, received from RTCM message","    case failed(String)","","    \/\/ HTTP response error, received from server","    case httpResponceError(String)","","    \/\/ Server is not responding","    case serverIsNotResponce","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","type":"reference","isActive":true}],"type":"paragraph"}]}]},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError"},{"text":" are thrown, when due to the filtering phase of single point recordings there is not enough valid data to create a singlePoint. To investigate possible issues with the measurement, have a look at the provided associated data.","type":"text"}],"type":"paragraph"},{"code":["public enum SinglePointRecordingError: Error, Hashable {","","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/","\/\/ Available in SDK ver. 1.0.3","case nonValidData","","\/\/ This method is not supported in current software version of the RTK device","\/\/","\/\/ Available in SDK ver. 1.0.3","case requestIsNotSupported(String)","","\/\/ The correction method used has incorrect settings","\/\/ Most likely the CoordinateCorrectionMethod settings ","\/\/ were not selected and passed to the write method correctly","\/\/","\/\/ Available in SDK ver. 1.0.3","case incorrectCoordinateCorrectionMethod(String)","","\/\/ Running measurement process not found","\/\/","\/\/ Available in SDK ver. 1.0.3","case noRunningMeasurementMethod","","\/\/ The value of horizontal accuracy is too high","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case horizontalAccuracyIsTooHigh","","\/\/ The value of vertical accuracy is too high","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case verticalAccuracyIsTooHigh","","\/\/ The value of altitude difference is too high","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/","\/\/ Available in SDK ver. 1.0.3","case altitudeDifferenceIsTooHigh","","\/\/ The laser measurements are of bad quality","\/\/","\/\/ This means that most of the laser measurements were of bad ","\/\/ quality or incorrect.","\/\/","\/\/ Available in SDK ver. 1.0.3","case laserMeasurementsIsBadQuality","","\/\/ The measurement cancelled by user.","case measurementCancelled","","\/\/ Deprecated!","\/\/","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/ Most of the measured data have low accuracy.","\/\/ e.g. One or more conditions are not met","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy,","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/ The returned RAW value of this error is the received measurements.","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case badMeasurement([EnvironmentData])","","\/\/ Deprecated!","\/\/","\/\/ The measurement failure.","\/\/ In most cases this error is not returned. ","\/\/ If you get it, check if you passed the correct ","\/\/ CoordinateCorrection.Method to the SinglePointRecordingService ","\/\/ measurement procedure (record or startMeasurements).","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case measurementFailure","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/vigramsdk\/sdkerrorsandexceptions"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK/BluetoothServiceError":{"title":"BluetoothServiceError","type":"topic","navigatorTitle":[{"kind":"identifier","text":"BluetoothServiceError"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError","url":"\/documentation\/vigramsdk\/bluetoothserviceerror","kind":"symbol","role":"symbol","abstract":[{"text":"BluetoothServiceError list