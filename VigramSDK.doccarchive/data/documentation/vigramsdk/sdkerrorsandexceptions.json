d from the received data.","    case mountPointDecodingFailed","","    \/\/ Creating the URL to connect to Ntrip endpoints did not succeed.","    case couldNotCreateURL(NtripConnectionInformation, ","                           mountPoint: String?)","","    \/\/ We could not create an Ntrip task due to unexplicable ","    \/\/ circumstances.","    \/\/ Note: This error should never be thrown.","    case couldNotCreateTask","","    \/\/ Adding authentication to a URLRequest did not succeed.","    case couldNotAddAuthentication(URLRequest, username: String, ","                                   password: String)","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError","type":"reference"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTaskError","type":"reference"},{"text":" lists different errors that can be emitted by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/NtripTask","type":"reference"},{"text":" implementations.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["public enum NtripTaskError: Swift.Error {","","    \/\/ Creating the Ntrip network request failed.","    case couldNotCreateRequest","","    \/\/ Failed due to no data","    case noData","","    \/\/ Ntrip connection information (domain, port, or cridential) ","    \/\/ is incorrect","    case incorrectNCI","","    \/\/ Other error, received from RTCM message","    case failed(String)","","    \/\/ HTTP response error, received from server","    case httpResponceError(String)","","    \/\/ Server is not responding","    case serverIsNotResponce","}"]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","isActive":true,"type":"reference"}]}]}]},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","type":"reference"},{"type":"text","text":" are thrown, when due to the filtering phase of single point recordings there is not enough valid data to create a singlePoint. To investigate possible issues with the measurement, have a look at the provided associated data."}]},{"type":"codeListing","code":["public enum SinglePointRecordingError: Error, Hashable {","","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/","\/\/ Available in SDK ver. 1.0.3","case nonValidData","","\/\/ This method is not supported in current software version of the RTK device","\/\/","\/\/ Available in SDK ver. 1.0.3","case requestIsNotSupported(String)","","\/\/ The correction method used has incorrect settings","\/\/ Most likely the CoordinateCorrectionMethod settings ","\/\/ were not selected and passed to the write method correctly","\/\/","\/\/ Available in SDK ver. 1.0.3","case incorrectCoordinateCorrectionMethod(String)","","\/\/ Running measurement process not found","\/\/","\/\/ Available in SDK ver. 1.0.3","case noRunningMeasurementMethod","","\/\/ The value of horizontal accuracy is too high","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case horizontalAccuracyIsTooHigh","","\/\/ The value of vertical accuracy is too high","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case verticalAccuracyIsTooHigh","","\/\/ The value of altitude difference is too high","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/","\/\/ Available in SDK ver. 1.0.3","case altitudeDifferenceIsTooHigh","","\/\/ The laser measurements are of bad quality","\/\/","\/\/ This means that most of the laser measurements were of bad ","\/\/ quality or incorrect.","\/\/","\/\/ Available in SDK ver. 1.0.3","case laserMeasurementsIsBadQuality","","\/\/ The measurement cancelled by user.","case measurementCancelled","","\/\/ Deprecated!","\/\/","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/ Most of the measured data have low accuracy.","\/\/ e.g. One or more conditions are not met","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy,","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/ The returned RAW value of this error is the received measurements.","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case badMeasurement([EnvironmentData])","","\/\/ Deprecated!","\/\/","\/\/ The measurement failure.","\/\/ In most cases this error is not returned. ","\/\/ If you get it, check if you passed the correct ","\/\/ CoordinateCorrection.Method to the SinglePointRecordingService ","\/\/ measurement procedure (record or startMeasurements).","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case measurementFailure","}"],"syntax":"swift"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/sdkerrorsandexceptions"]}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.vigramsdk/documentation/VigramSDK/BluetoothServiceError":{"type":"topic","url":"\/documentation\/vigramsdk\/bluetoothserviceerror","role":"symbol","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/BluetoothServiceError","abstract":[{"type":"text","text":"BluetoothServiceError lists different errors that can be propagated by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/