{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"","anchor":""},{"inlineContent":[{"text":"If you need use PPK Measurements first need to activate RXM messages, performing this method:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["peripheral.changeStatusRXM(activate: Bool)"],"type":"codeListing"},{"inlineContent":[{"text":"Note: activate - enable \/ disable RXM messages","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To receive UBX-RXM-RAWX or UBX-RXM-SFRBX messages use:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["peripheral.satelliteMessages.sink(receiveValue: { satelliteMessage in","    switch satelliteMessage {","        case let .rawx(rawxMessage):","            \/\/ do something with rawxMessage","        case let .sfrbx(sfrbxMessage):","            \/\/ do something with sfrbxMessage","        default:","            break","        }","    }).store(in: &subscription)"],"type":"codeListing"},{"inlineContent":[{"text":"If need to record PPK measurement to file, first create URL path for ubx file.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"file.ubx\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(","    for: .documentDirectory, ","    in: .userDomainMask",")","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"After then, start record measurements perform this method","type":"text"}],"type":"paragraph"},{"code":["peripheral.startRecordPPKMeasurements(url: ubxFilePath)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Record is active."},{"text":" ","type":"text"},{"text":"If you need to stop record measurements perform this method","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["peripheral.stopRecordPPKMeasurements()"]},{"inlineContent":[{"text":"All messages will saving to file","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useppkmeasurements"]}],"metadata":{"roleHeading":"Article","title":"Use UBX PPK Measurements","role":"article","images":[{"type":"icon","identifier":"logo.png"}],"modules":[{"name":"VigramSDK"}]},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePPKMeasurements"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","role":"collection","abstract":[],"url":"\/documentation\/vigramsdk","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","title":"VigramSDK"},"logo.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"type":"image","alt":"Vigram logo.","identifier":"logo.png"}}}