anager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After then, start record measurements perform this method"}]},{"type":"codeListing","syntax":"swift","code":["peripheral.startRecordPPKMeasurements(url: ubxFilePath)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Record is active."},{"type":"text","text":" "},{"type":"text","text":"If you need to stop record measurements perform this method"}]},{"type":"codeListing","syntax":"swift","code":["peripheral.stopRecordPPKMeasurements()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All messages will saving to file"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"Use UBX PPK Measurements","modules":[{"name":"VigramSDK"}],"roleHeading":"Article","images":[{"type":"icon","identifier":"logo.png"}],"role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useppkmeasurements"]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"symbol","type":"topic","abstract":[],"url":"\/documentation\/vigramsdk","title":"VigramSDK","role":"collection","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"logo.png":{"type":"image","alt":"Vigram logo.","identifier":"logo.png","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}]}}}