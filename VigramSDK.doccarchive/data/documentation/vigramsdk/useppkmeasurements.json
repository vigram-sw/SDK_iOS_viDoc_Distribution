{"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"anchor":"","level":2,"type":"heading","text":""},{"inlineContent":[{"text":"If you need use PPK Measurements first need to activate RXM messages, performing this method:","type":"text"}],"type":"paragraph"},{"code":["peripheral.changeStatusRXM(activate: Bool)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Note: activate - enable \/ disable RXM messages"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To receive UBX-RXM-RAWX or UBX-RXM-SFRBX messages use:"}],"type":"paragraph"},{"code":["peripheral.satelliteMessages.sink(receiveValue: { satelliteMessage in","    switch satelliteMessage {","        case let .rawx(rawxMessage):","            \/\/ do something with rawxMessage","        case let .sfrbx(sfrbxMessage):","            \/\/ do something with sfrbxMessage","        default:","            break","        }","    }).store(in: &subscription)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If need to record PPK measurement to file, first create URL path for ubx file."},{"type":"text","text":" "},{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"file.ubx\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(","    for: .documentDirectory, ","    in: .userDomainMask",")","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"After then, start record measurements perform this method"}],"type":"paragraph"},{"code":["peripheral.startRecordPPKMeasurements(url: ubxFilePath)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Record is active."},{"type":"text","text":" "},{"type":"text","text":"If you need to stop record measurements perform this method"}],"type":"paragraph"},{"code":["peripheral.stopRecordPPKMeasurements()"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"All messages will saving to file"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"article","modules":[{"name":"VigramSDK"}],"title":"Use UBX PPK Measurements","images":[{"identifier":"logo.png","type":"icon"}],"roleHeading":"Article"},"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePPKMeasurements","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useppkmeasurements"]}],"kind":"article","references":{"logo.png":{"type":"image","alt":"Vigram logo.","identifier":"logo.png","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}]},"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","title":"VigramSDK","abstract":[],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","url":"\/documentation\/vigramsdk","role":"collection"}}}