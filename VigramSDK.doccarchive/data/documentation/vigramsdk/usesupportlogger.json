{"metadata":{"roleHeading":"Article","title":"Use Support Logger","images":[{"identifier":"logo.png","type":"icon"}],"role":"article","modules":[{"name":"VigramSDK"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/usesupportlogger"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","primaryContentSections":[{"content":[{"level":2,"anchor":"","type":"heading","text":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one structured support logger file and let the SDK write JSON Lines ("},{"type":"codeVoice","code":".jsonl"},{"type":"text","text":") into it."},{"type":"text","text":" "},{"type":"text","text":"Example:"}]},{"syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After that, configure the SDK logger once:"}]},{"syntax":"swift","type":"codeListing","code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a deeper trace for support, switch to diagnostic mode:"}]},{"syntax":"swift","type":"codeListing","code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"]},{"type":"paragraph","inlineContent":[{"text":"The SDK writes structured support events into this file automatically.","type":"text"}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"references":{"logo.png":{"variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"alt":"Vigram logo.","type":"image","identifier":"logo.png"},"doc://com.vigramsdk/documentation/VigramSDK":{"abstract":[],"title":"VigramSDK","images":[{"type":"icon","identifier":"logo.png"}],"role":"collection","url":"\/documentation\/vigramsdk","kind":"symbol","type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"}}}