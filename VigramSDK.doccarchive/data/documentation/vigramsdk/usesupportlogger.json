{"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"VigramSDK"}],"title":"Use Support Logger","roleHeading":"Article","role":"article","images":[{"identifier":"logo.png","type":"icon"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"level":2,"text":"","anchor":"","type":"heading"},{"inlineContent":[{"type":"text","text":"Create one structured support logger file and let the SDK write JSON Lines ("},{"code":".jsonl","type":"codeVoice"},{"type":"text","text":") into it."},{"type":"text","text":" "},{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"After that, configure the SDK logger once:"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need a deeper trace for support, switch to diagnostic mode:"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The SDK writes structured support events into this file automatically."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/usesupportlogger"]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","role":"collection","abstract":[],"url":"\/documentation\/vigramsdk","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","title":"VigramSDK"},"logo.png":{"alt":"Vigram logo.","identifier":"logo.png","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"type":"image"}}}