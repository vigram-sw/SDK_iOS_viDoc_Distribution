{"kind":"article","metadata":{"roleHeading":"Article","images":[{"identifier":"logo.png","type":"icon"}],"title":"Use Support Logger","role":"article","modules":[{"name":"VigramSDK"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/usesupportlogger"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"","type":"heading","text":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one structured support logger file and let the SDK write JSON Lines ("},{"code":".jsonl","type":"codeVoice"},{"type":"text","text":") into it."},{"type":"text","text":" "},{"type":"text","text":"Example:"}]},{"syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After that, configure the SDK logger once:"}]},{"syntax":"swift","code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a deeper trace for support, switch to diagnostic mode:"}]},{"syntax":"swift","code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK writes structured support events into this file automatically."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"},"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"images":[{"type":"icon","identifier":"logo.png"}],"kind":"symbol","type":"topic","abstract":[],"url":"\/documentation\/vigramsdk","title":"VigramSDK","role":"collection","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"logo.png":{"identifier":"logo.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"alt":"Vigram logo."}}}