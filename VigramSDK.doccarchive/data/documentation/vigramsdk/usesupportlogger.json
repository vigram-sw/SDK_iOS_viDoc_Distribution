{"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"},"primaryContentSections":[{"content":[{"anchor":"","type":"heading","text":"","level":2},{"type":"paragraph","inlineContent":[{"text":"Create one structured support logger file and let the SDK write JSON Lines (","type":"text"},{"type":"codeVoice","code":".jsonl"},{"text":") into it.","type":"text"},{"text":" ","type":"text"},{"text":"Example:","type":"text"}]},{"code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"After that, configure the SDK logger once:","type":"text"}]},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you need a deeper trace for support, switch to diagnostic mode:","type":"text"}]},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"],"syntax":"swift","type":"codeListing"},{"