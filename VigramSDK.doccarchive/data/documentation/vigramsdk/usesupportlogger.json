{"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"VigramSDK"}],"title":"Use Support Logger","images":[{"type":"icon","identifier":"logo.png"}]},"variants":[{"paths":["\/documentation\/vigramsdk\/usesupportlogger"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"anchor":"","level":2,"type":"heading","text":""},{"inlineContent":[{"type":"text","text":"Create one structured support logger file and let the SDK write JSON Lines ("},{"type":"codeVoice","code":".jsonl"},{"type":"text","text":") into it."},{"type":"text","text":" "},{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing"},{"inlineContent":[{"text":"After that, configure the SDK logger once:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"]},{"type":"paragraph","inlineContent":[{"text":"If you need a deeper trace for support, switch to diagnostic mode:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"]},{"type":"paragraph","inlineContent":[{"text":"The SDK writes structured support events into this file automatically.","type":"text"}]}],"kind":"content"}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"logo.png":{"type":"image","alt":"Vigram logo.","variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"identifier":"logo.png"},"doc://com.vigramsdk/documentation/VigramSDK":{"kind":"symbol","title":"VigramSDK","abstract":[],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","images":[{"identifier":"logo.png","type":"icon"}],"type":"topic","url":"\/documentation\/vigramsdk","role":"collection"}}}