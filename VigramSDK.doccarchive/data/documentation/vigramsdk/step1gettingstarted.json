{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/step1gettingstarted"]}],"sections":[],"metadata":{"title":"Import VigramSDK","modules":[{"name":"VigramSDK"}],"images":[{"type":"icon","identifier":"logo.png"}],"roleHeading":"Article","role":"article"},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To connect VigramSDK in this example we will use "},{"identifier":"https:\/\/www.swift.org\/package-manager\/","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"We also recommend using this method instead of CocoaPods."}]},{"anchor":"Step-1-Add-Package-Dependencies-in-your-project","text":"Step 1. Add Package Dependencies in your project.","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add a framework to your project, you need to select Add Package Dependencies in the "},{"type":"strong","inlineContent":[{"type":"text","text":"File"}]},{"type":"text","text":" section of the top menu of Xcode:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig1.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste into the search bar url:"}]},{"code":["https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution.git"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"identifier":"fig2.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After entering the address, the SDK name, the current release version, and the project to which the library will be added will appear:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig3.png","type":"image"}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure you have access to an internet connection and that the project you are adding the framework to is selected correctly"},{"type":"text","text":" "},{"type":"text","text":"Also pay attention to the release version indicated in the window. The version number can be changed manually."},{"type":"text","text":" "},{"type":"text","text":"The actual release version is always indicated on the main page of this guide."}]}],"style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After this, you need to click on the Add Package button:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig4.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After this, the process of checking and unpacking the library will begin. Wait until it is finished:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig5.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Select your project:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig6.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you add the project, the dependency will appear in the "},{"type":"strong","inlineContent":[{"type":"text","text":"Package Dependencies"}]},{"type":"text","text":" section of your project. Again, pay attention to the library version:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig7.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Try building the project. To do this, select the Build command in the "},{"type":"strong","inlineContent":[{"type":"text","text":"Product"}]},{"type":"text","text":" section or run the command using hotkeys ("},{"type":"strong","inlineContent":[{"type":"text","text":"command + b"}]},{"type":"text","text":")"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig8.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the project builds successfully, all actions have been performed correctly."}]},{"anchor":"Step-2-Import-library","text":"Step 2. Import library","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use VigramSDK tools you need to import framework into your class:"}]},{"code":["import VigramSDK"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"identifier":"fig9.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This completes the framework import procedure."}]},{"type":"paragraph","inlineContent":[{"text":"The next step is ","type":"text"},{"type":"strong","inlineContent":[{"overridingTitle":"to authenticate the SDK.","isActive":true,"overridingTitleInlineContent":[{"text":"to authenticate the SDK.","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"}]}]},{"type":"paragraph","inlineContent":[{"text":"*All methods and functions specified in this manual are also available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}]},{"type":"heading","level":2,"text":"Navigation","anchor":"Navigation"},{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"Up to Getting started with VigramSDK","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","overridingTitle":"Up to Getting started with VigramSDK"}]},{"inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"STEP 1 (Import VigramSDK)","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","type":"reference","isActive":true,"overridingTitle":"STEP 2 (SDK Authentication)","overridingTitleInlineContent":[{"text":"STEP 2 (SDK Authentication)","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"overridingTitle":"STEP 3 (Description of configuration parameters)","isActive"