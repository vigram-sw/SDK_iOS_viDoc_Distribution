{"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"To connect VigramSDK in this example we will use ","type":"text"},{"identifier":"https:\/\/www.swift.org\/package-manager\/","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"We also recommend using this method instead of CocoaPods.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-1-Add-Package-Dependencies-in-your-project","text":"Step 1. Add Package Dependencies in your project.","type":"heading"},{"inlineContent":[{"text":"To add a framework to your project, you need to select Add Package Dependencies in the ","type":"text"},{"inlineContent":[{"type":"text","text":"File"}],"type":"strong"},{"text":" section of the top menu of Xcode:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig1.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste into the search bar url:","type":"text"}],"type":"paragraph"},{"code":["https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution.git"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"identifier":"fig2.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"After entering the address, the SDK name, the current release version, and the project to which the library will be added will appear:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig3.png","type":"image"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Make sure you have access to an internet connection and that the project you are adding the framework to is selected correctly"},{"type":"text","text":" "},{"type":"text","text":"Also pay attention to the release version indicated in the window. The version number can be changed manually."},{"type":"text","text":" "},{"type":"text","text":"The actual release version is always indicated on the main page of this guide."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"text":"After this, you need to click on the Add Package button:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig4.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"After this, the process of checking and unpacking the library will begin. Wait until it is finished:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig5.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Select your project:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig6.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Once you add the project, the dependency will appear in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Package Dependencies"}],"type":"strong"},{"text":" section of your project. Again, pay attention to the library version:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig7.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Try building the project. To do this, select the Build command in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Product"}],"type":"strong"},{"text":" section or run the command using hotkeys (","type":"text"},{"inlineContent":[{"type":"text","text":"command + b"}],"type":"strong"},{"text":")","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig8.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"If the project builds successfully, all actions have been performed correctly.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-2-Import-library","text":"Step 2. Import library","type":"heading"},{"inlineContent":[{"text":"To use VigramSDK tools you need to import framework into your class:","type":"text"}],"type":"paragraph"},{"code":["import VigramSDK"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"identifier":"fig9.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the framework import procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"inlineContent":[{"type":"reference","overridingTitle":"to authenticate the SDK.","overridingTitleInlineContent":[{"text":"to authenticate the SDK.","type":"text"}],"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"*All methods and functions specified in this manual are also available in the ","type":"text"},{"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","isActive":true,"type":"reference"}],"type":"paragraph"},{"level":2,"anchor":"Navigation","text":"Navigation","type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Up to Getting started with VigramSDK"}],"overridingTitle":"Up to Getting started with VigramSDK","type":"reference"}],"type":"paragraph"},{"inlineContent":[{"text":"✅ ","type":"text"},{"inlineContent":[{"type":"text","text":"STEP 1 (Import VigramSDK)"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"STEP 2 (SDK Authentication)"}],"overridingTitle":"STEP 2 (SDK Authentication)","type":"reference"}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters","is