t","text":"If the project builds successfully, all actions have been performed correctly."}],"type":"paragraph"},{"anchor":"Step-2-Import-library","level":2,"type":"heading","text":"Step 2. Import library"},{"inlineContent":[{"type":"text","text":"To use VigramSDK tools you need to import framework into your class:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["import VigramSDK"]},{"inlineContent":[{"type":"image","identifier":"fig9.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This completes the framework import procedure."}],"type":"paragraph"},{"inlineContent":[{"text":"The next step is ","type":"text"},{"type":"strong","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","overridingTitleInlineContent":[{"type":"text","text":"to authenticate the SDK."}],"overridingTitle":"to authenticate the SDK.","type":"reference","isActive":true}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"*All methods and functions specified in this manual are also available in the "},{"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","isActive":true}],"type":"paragraph"},{"anchor":"Navigation","level":2,"type":"heading","text":"Navigation"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","isActive":true,"overridingTitle":"Up to Getting started with VigramSDK","overridingTitleInlineContent":[{"type":"text","text":"Up to Getting started with VigramSDK"}],"type":"reference"}]},{"type":"paragraph","inlineContent":[{"text":"✅ ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"STEP 1 (Import VigramSDK)"}]}]},{"type":"paragraph","inlineContent":[{"overridingTitle":"STEP 2 (SDK Authentication)","overridingTitleInlineContent":[{"text":"STEP 2 (SDK Authentication)","type":"text"}],"isActive":true,"type":"reference","identifier":"doc:\/\/com.