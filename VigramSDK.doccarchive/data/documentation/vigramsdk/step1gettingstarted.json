{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted"},"metadata":{"title":"Import VigramSDK","roleHeading":"Article","modules":[{"name":"VigramSDK"}],"images":[{"type":"icon","identifier":"logo.png"}],"role":"article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To connect VigramSDK in this example we will use "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.swift.org\/package-manager\/"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"We also recommend using this method instead of CocoaPods."}]},{"anchor":"Step-1-Add-Package-Dependencies-in-your-project","level":2,"type":"heading","text":"Step 1. Add Package Dependencies in your project."},{"type":"paragraph","inlineContent":[{"text":"To add a framework to your project, you need to select Add Package Dependencies in the ","type":"text"},{"inlineContent":[{"text":"File","type":"text"}],"type":"strong"},{"text":" section of the top menu of Xcode:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig1.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste into the search bar url:"}]},{"syntax":null,"type":"codeListing","code":["https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution.git"]},{"type":"paragraph","inlineContent":[{"identifier":"fig2.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After entering the address, the SDK name, the current release version, and the project to which the library will be added will appear:"}]},{"type":"paragraph","inlineContent":[{"identifier":"fig3.png","type":"image"}]},{"type":"aside","nam