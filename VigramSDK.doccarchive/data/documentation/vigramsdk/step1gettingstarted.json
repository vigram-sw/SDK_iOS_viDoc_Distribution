{"kind":"article","identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/step1gettingstarted"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"To connect VigramSDK in this example we will use "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.swift.org\/package-manager\/"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"We also recommend using this method instead of CocoaPods."}],"type":"paragraph"},{"text":"Step 1. Add Package Dependencies in your project.","level":2,"anchor":"Step-1-Add-Package-Dependencies-in-your-project","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add a framework to your project, you need to select Add Package Dependencies in the "},{"type":"strong","inlineContent":[{"type":"text","text":"File"}]},{"type":"text","text":" section of the top menu of Xcode:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"fig1.png"}]},{"type":"paragraph","inlineContent":[{"text":"Paste into the search bar url:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution.git"]},{"inlineContent":[{"identifier":"fig2.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After entering the address, the SDK name, the current release version, and the project to which the library will be added will appear:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig3.png"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"Make sure you have access to an internet connection and that the project you are adding the framework to is selected correctly","type":"text"},{"text":" ","type":"text"},{"text":"Also pay attention to the release version indicated in the window. The version number can be changed manually.","type":"text"},{"text":" ","type":"text"},{"text":"The actual release version is always indicated on the main page of this guide.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"text":"After this, you need to click on the Add Package button:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig4.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"After this, the process of checking and unpacking the library will begin. Wait until it is finished:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig5.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Select your project:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig6.png"}],"type":"paragraph"},{"inlineContent":[{"text":"Once you add the project, the dependency will appear in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Package Dependencies"}],"type":"strong"},{"text":" section of your project. Again, pay attention to the library version:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig7.png"}],"type":"paragraph"},{"inlineContent":[{"text":"Try building the project. To do this, select the Build command in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Product"}],"type":"strong"},{"text":" section or run the command using hotkeys (","type":"text"},{"inlineContent":[{"text":"command + b","type":"text"}],"type":"strong"},{"text":")","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"fig8.png","type":"image"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the project builds successfully, all actions have been performed correctly.","type":"text"}]},{"level":2,"anchor":"Step-2-Import-library","text":"Step 2. Import library","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use VigramSDK tools you need to import framework into your class:"}]},{"syntax":null,"type":"codeListing","code":["import VigramSDK"]},{"inlineContent":[{"identifier":"fig9.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the framework import procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The next step is "},{"type":"strong","inlineContent":[{"type":"reference","isActive":true,"overridingTitle":"to authenticate the SDK.","overridingTitleInlineContent":[{"type":"text","text":"to authenticate the SDK."}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"*All methods and functions specified in this manual are also available in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Navigation","anchor":"Navigation"},{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"Up to Getting started with VigramSDK"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","overridingTitle":"Up to Getting started with VigramSDK","type":"reference","isActive":true}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"STEP 1 (Import VigramSDK)","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"STEP 2 (SDK Authentication)"}],"overridingTitle":"STEP 2 (SDK Authentication)"}],"type":"paragraph"},{"inlineContent":[{"overridingTitle":"STEP 3 (Description of configuration parameters)","overridingTitleInlineContent":[{"t