{"metadata":{"title":"Using Single point measurements","roleHeading":"Article","role":"article","modules":[{"name":"VigramSDK"}],"images":[{"identifier":"logo.png","type":"icon"}]},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","type":"reference","isActive":true},{"type":"text","text":" can be used to record single points over a given duration. During the recording phase, the service will keep track of all the environment’s data and then merge individual measurements to one combined single point."}]},{"type":"paragraph","inlineContent":[{"text":"Please make sure that during the recording of single points, there are only minimal position changes, since the recording will otherwise fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"It is recommended that you review these sections before proceeding.","type":"text"}]}]},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/combine"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","isActive":true,"overridingTitle":"Using Combine and Publishers","overridingTitleInlineContent":[{"type":"text","text":"Using Combine and Publishers"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","overridingTitle":"SDK Errors and exceptions","over