{"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","type":"reference","isActive":true},{"text":" can be used to record single points over a given duration. During the recording phase, the service will keep track of all the environment’s data and then merge individual measurements to one combined single point.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Please make sure that during the recording of single points, there are only minimal position changes, since the recording will otherwise fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"It is recommended that you review these sections before proceeding."}]}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/combine"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitle":"Using Combine and Publishers"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErr