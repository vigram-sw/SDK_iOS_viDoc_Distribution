{"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"sections":[],"metadata":{"roleHeading":"Article","title":"Using Single point measurements","role":"article","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"VigramSDK"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/step8singlepoint"]}],"kind":"article","primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","isActive":true,"type":"reference"},{"type":"text","text":" can be used to record single points over a given duration. During the recording phase, the service will keep track of all the environment’s data and then merge individual measurements to one combined single point."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Please make sure that during the recording of single points, there are only minimal position changes, since the recording will otherwise fail."}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"It is recommended that you review these sections before proceeding."}],"type":"strong"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/combine"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","overridingTitle":"Using Combine and Publishers","overridingTitleInlineContent":[{"type":"text","text":"Using Combine and Publishers"}],