arted.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For start measurement, perform this method","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["singlePointService","    .record(duration: duration, ","            updateInterval: updateInterval, ","            with: method)","    .sink(receiveCompletion: { completion in ","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    }) { singlePointValue in","        \/\/ do somethind with singlePointValue","    }.store(in: &subscription)"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Receive value:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Throw error:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError"}]},{"type":"heading","level":3,"text":"More information about","anchor":"More-information-about"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnvironmentData"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"EnviromentDataService","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService","overridingTitle":"EnviromentDataService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"GPSService","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","overridingTitle":"GPSService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"LaserService","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService","overridingTitle":"LaserService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"Use GPSCoordinate + Transformation","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GPSCoordinate","overridingTitle":"Use GPSCoordinate + Transformation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitle":"Using Combine and Publishers"}]}]}]},{"type":"heading","level":2,"text":"New protocol methods","anchor":"New-protocol-methods"},{"type":"paragraph","inlineContent":[{"text":"The new version of the protocol has no restrictions on measurement time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note: If set the duration value to 0, the measurement will go on infinity. If need to terminate measurements, perform the method stopMeasurement.","type":"text"},{"text":" ","type":"text"},{"text":"(Available only on the new protocol - HW of viDoc 0.2.1.(12) and up)","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["singlePointRecordingService","    .startMeasurement()","    .sink(receiveCompletion: { completion in ","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    }) { singlePointValue in","        \/\/ do somethind with singlePointValue","    }.store(in: &subscription)"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Receive value:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Throw error:"}]},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError"}]},{"type":"heading","level":3,"text":"More information about","anchor":"More-information-about"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnvironmentData"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"EnviromentDataService","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService","overridingTitle":"EnviromentDataService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"