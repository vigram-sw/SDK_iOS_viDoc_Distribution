paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["singlePointRecordingService","    .measurementTime","    .sink { value in","        \/\/ do somethind with value","    }.store(in: &subscription)"]},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"All methods and functions specified in this manual are also available in the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"An important section is ","type":"text"},{"isActive":true,"overridingTitle":"Use Antenna Offsets","overridingTitleInlineContent":[{"text":"Use Antenna Offsets","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseAntennaOffsets"}]},{"type":"text","text":" "},{"text":"Note: Offsets have a data type ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3"}]},{"type":"paragraph","inlineContent":[{"text":"You can set your own custom offsets","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let yourCustomOffset = SIMD3(x: 4.4, y: -1.6, z: 2) \/ 100"]},{"type":"heading","level":2,"text":"Detailed listing Single Point measurements with laser","anchor":"Detailed-listing-Single-Point-measurements-with-laser"},{"type":"codeListing","syntax":"swift","code":["\/\/ Bottom laser selected (or .back if needed)","let typeOfLaser: LaserConfiguration.Position = .bottom","","\/\/ Laser measurement mode - fast","let laserShotMode: LaserConfiguration.ShotMode = .fast ","","\/\/ Measurement duration (in seconds). ","\/\/ For viDoc protocol version < 2, the measurement duration","\/\/ must be in the range [5...60] seconds.","\/\/","\/\/ For protocol >= 2, any value can be specified. If 0 is ","\/\/ specified, the measurement will continue ","\/\/ indefinitely.","\/\/ ","\/\/ More details in section №8 (Using Single point measurements)","let duration: Double = 30","","\/\/ Creating a laser configuration. ","\/\/ The laser configuration. Keep in mind, that you will not receive ","\/\/ further environment data values after the laser duration has passed.","let laserConfig = LaserConfiguration.init(shotMode: laserShotMode, ","                                          position: typeOfLaser, ","                                          duration: duration)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.Laser.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ UseDeviceMotion - This attribute specifies whether to incorporate ","\/\/ the device motion into the calculation of the corrected coordinate. ","\/\/ This allows to not only correct coordinates by strictly subtracting ","\/\/ the laser distance measurement from the measured antenna position,","\/\/ but rather enables diagonally held laser measurements as well.","let method = ","    CoordinateCorrection.Method.laser(configuration: laserConfig, ","                                      antennaOffset: offset,","                                      useDeviceMotion: true)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  laserService: laserService!,","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","\/\/ Start SinglePoint measurements","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }","","\/\/ For stop measurement use this method","\/\/ Important! Use it only when setting the time to 0 (infinite ","\/\/ measurement). After executing this method, the measurement ","\/\/ will end.","singlePointRecordingService!.stopMeasurement()","","\/\/ Important! Use only when time is set to 0 ","\/\/ (infinite measurement). ","\/\/ After this method is executed, the measurement will stop. ","\/\/ The data will NOT BE SAVED.","singlePointRecordingService?.cancelMeasurement()","","\/\/ If you are using an infinite measurement (duration - 0) ","\/\/ and need to track the time of the dimension,","\/\/ use this publisher.","\/\/ Note: The time will starts after the first successful laser ","\/\/ measurement (quality >= acceptable)","let cancellable = singlePointRecordingService!","    .measurementTime","    .sink { time in","        \/\/ do something with measurement time","    }"]},{"type":"heading","level":2,"text":"Detailed listing Single Point measurements without laser","anchor":"Detailed-listing-Single-Point-measurements-without-laser"},{"type":"codeListing","syntax":"swift","code":["\/\/ The distance from the antenna to the ground to subtract from the ","\/\/ antenna’s coordinate’s altitude.","let distanceToGround = Double(distanceToGround)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.SPC.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ When using the constant height coordinate correction,","\/\/ the correctedCoordinate property of EnvironmentData will reflect ","\/\/ the position of the antenna with an altitude subtracted by the ","\/\/ constant value.","let method = ","    CoordinateCorrection.Method","        .constant(distanceFromAntennaToGround: antennaDistanceToGround)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"]},{"type":"heading","level":3,"text":"SinglePointRecordingError","anchor":"SinglePointRecordingError"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError"},{"type":"text","text":" are thrown, when due to the filtering phase of single point recordings there is not enough valid data to create a singlePoint. To investigate possible issues with the measurement, have a look at the provided associated data."}]},{"type":"codeListing","code":["public enum SinglePointRecordingError: Error, Hashable {","","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/","\/\/ Available in SDK ver. 1.0.3","case nonValidData","","\/\/ This method is not supported in current software version of ","\/\/ the RTK device","\/\/","\/\/ Available in SDK ver. 1.0.3","case requestIsNotSupported(String)","","\/\/ The correction method used has incorrect settings","\/\/ Most likely the CoordinateCorrectionMethod settings ","\/\/ were not selected and passed to the write method correctly","\/\/","\/\/ Available in SDK ver. 1.0.3","case incorrectCoordinateCorrectionMethod(String)","","\/\/ Running measurement process not found","\/\/","\/\/ Available in SDK ver. 1.0.3","case noRunningMeasurementMethod","","\/\/ The value of horizontal accuracy is too high","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case horizontalAccuracyIsTooHigh","","\/\/ The value of vertical accuracy is too high","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case verticalAccuracyIsTooHigh","","\/\/ The value of altitude difference is too high","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/","\/\/ Available in SDK ver. 1.0.3","case altitudeDifferenceIsTooHigh","","\/\/ The laser measurements are of bad quality","\/\/","\/\/ This means that most of the laser measurements were of bad ","\/\/ quality or incorrect.","\/\/","\/\/ Available in SDK ver. 1.0.3","case laserMeasurementsIsBadQuality","","\/\/ The measurement cancelled by user.","case measurementCancelled","","\/\/ Deprecated!","\/\/","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/ Most of the measured data have low accuracy.","\/\/ e.g. One or more conditions are not met","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy,","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/ The returned RAW value of this error is the received measurements.","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case badMeasurement([EnvironmentData])","","\/\/ Deprecated!","\/\/","\/\/ The measurement failure.","\/\/ In most cases this error is not returned. ","\/\/ If you get it, check if you passed the correct ","\/\/ CoordinateCorrection.Method to the SinglePointRecordingService ","\/\/ measurement procedure (record or startMeasurements).","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case measurementFailure","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"More information about","anchor":"More-information-about"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"Peripheral","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Peripheral"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"GPSService","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"GPSService"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"LaserService","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"LaserService"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"EnviromentDataService","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"EnviromentDataService"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService"}]}]},{"content":[{"inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"Use GPSCoordinate + Transformation","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GPSCoordinate","overridingTitle":"Use GPSCoordinate + Transformation"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Navigation","anchor":"Navigation"},{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitle":"Up to Getting started with VigramSDK","overridingTitleInlineContent":[{"type":"text","text":"Up to Getting started with VigramSDK"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted"}]},{"inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"✅ STEP 1 (Import VigramSDK)","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted","overridingTitle":"✅ STEP 1 (Import VigramSDK)"}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"✅ STEP 2 (SDK Authentication)","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step2SDKAuthentication","overridingTitle":"✅ STEP 2 (SDK Authentication)"}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"overridin