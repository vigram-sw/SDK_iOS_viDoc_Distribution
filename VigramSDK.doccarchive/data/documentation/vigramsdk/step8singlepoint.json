{"metadata":{"modules":[{"name":"VigramSDK"}],"role":"article","title":"Using Single point measurements","images":[{"type":"icon","identifier":"logo.png"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint"},{"type":"text","text":" can be used to record single points over a given duration. During the recording phase, the service will keep track of all the environment’s data and then merge individual measurements to one combined single point."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Please make sure that during the recording of single points, there are only minimal position changes, since the recording will otherwise fail."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"It is recommended that you review these sections before proceeding."}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/combine","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"Using Combine and Publishers","type":"reference","overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","isActive":true}]}]},{"content":[{"inlineContent":[{"overridingTitle":"SDK Errors and exceptions","type":"reference","overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}],"isActive":true,"identifier":"doc:\/\/com.v