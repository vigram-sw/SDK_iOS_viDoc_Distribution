{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"","text":"","type":"heading"},{"inlineContent":[{"text":"If you need use PPK Measurements first need to activate RXM messages, performing this method:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["peripheral.changeStatusRXM(activate: Bool)"],"type":"codeListing"},{"inlineContent":[{"text":"Note: activate - enable \/ disable RXM messages","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To receive UBX-RXM-RAWX or UBX-RXM-SFRBX messages use:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["peripheral.satelliteMessages.sink(receiveValue: { satelliteMessage in","    switch satelliteMessage {","        case let .rawx(rawxMessage):","            \/\/ do something with rawxMessage","        case let .sfrbx(sfrbxMessage):","            \/\/ do something with sfrbxMessage","        default:","            break","        }","    }).store(in: &subscription)"],"type":"codeListing"},{"inlineContent":[{"text":"If need to record PPK measurement to file, first create URL path for ubx file.","type":"text"},{"text":" ","type":"text"},{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"file.ubx\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(","    for: .documentDirectory, ","    in: .userDomainMask",")","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing"},{"inlineContent":[{"text":"After then, start record measurements perform this method","type":"text"}],"type":"paragraph"},{"code":["peripheral.startRecordPPKMeasurements(url: ubxFilePath)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Record is active."},{"type":"text","text":" "},{"type":"text","text":"If you need to stop record measurements perform this method"}]},{"syntax":"swift","type":"codeListing","code":["peripheral.stopRecordPPKMeasurements()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All messages will saving to file"}]}]}],"variants":[{"paths":["\/documentation\/vigramsdk\/useppkmeasurements"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePPKMeasurements","interfaceLanguage":"swift"},"metadata":{"role":"article","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"VigramSDK"}],"title":"Use UBX PPK Measurements","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"sections":[],"kind":"article","references":{"doc://com.vigramsdk/documentation/VigramSDK":{"type":"topic","title":"VigramSDK","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","abstract":[],"kind":"symbol","role":"collection","url":"\/documentation\/vigramsdk","images":[{"type":"icon","identifier":"logo.png"}]},"logo.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"identifier":"logo.png","type":"image","alt":"Vigram logo."}}}