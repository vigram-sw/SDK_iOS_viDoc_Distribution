{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","title":"Use UBX PPK Measurements","role":"article","images":[{"identifier":"logo.png","type":"icon"}]},"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePPKMeasurements","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"","type":"heading","level":2,"anchor":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need use PPK Measurements first need to activate RXM messages, performing this method:"}]},{"syntax":"swift","type":"codeListing","code":["peripheral.changeStatusRXM(activate: Bool)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note: activate - enable \/ disable RXM messages"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To receive UBX-RXM-RAWX or UBX-RXM-SFRBX messages use:"}]},{"syntax":"swift","type":"codeListing","code":["peripheral.satelliteMessages.sink(receiveValue: { satelliteMessage in","    switch satelliteMessage {","        case let .rawx(rawxMessage):","            \/\/ do something with rawxMessage","        case let .sfrbx(sfrbxMessage):","            \/\/ do something with sfrbxMessage","        default:","            break","        }","    }).store(in: &subscription)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If need to record PPK measurement to file, first create URL path for ubx file."},{"type":"text","text":" "},{"type":"text","text":"Example:"}]},{"syntax":"swift","type":"codeListing","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"file.ubx\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(","    for: .documentDirectory, ","    in: .userDomainMask",")","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After then, start record measurements perform this method"}]},{"syntax":"swift","type":"codeListing","code":["peripheral.startRecordPPKMeasurements(url: ubxFilePath)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Record is active."},{"type":"text","text":" "},{"type":"text","text":"If you need to stop record measurements perform this method"}]},{"type":"codeListing","code":["peripheral.stopRecordPPKMeasurements()"],"syntax":"swift"},{"inlineContent":[{"text":"All messages will saving to file","type":"text"}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useppkmeasurements"]}],"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"role":"collection","kind":"symbol","url":"\/documentation\/vigramsdk","images":[{"type":"icon","identifier":"logo.png"}],"title":"VigramSDK","abstract":[],"type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"logo.png":{"type":"image","alt":"Vigram logo.","variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"identifier":"logo.png"}}}