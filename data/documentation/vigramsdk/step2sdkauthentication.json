{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"VigramSDK is copyrighted and licensed. Therefore, in order to be able to use it, you need to obtain an authentication token. Please contact Vigram AG support to receive a token.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Authentication check is performed when calling any VigramSDK service:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"fig12.png"}],"type":"paragraph"},{"inlineContent":[{"text":"If the authentication procedure is not completed, access to the SDK functions will not be available","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"First, to use the SDK, you must be authenticated.","type":"text"},{"text":" ","type":"text"},{"text":"Creates a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Authentication","type":"reference"},{"text":" object to check your token.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import Combine","import VigramSDK","","final class YouVigramHelper: NSObject {","    let authentication: AnyCancellable?","","    public init() {","        super.init()","        authentication = Vigram.initial(token: \"your token\")","            .check()","            .receive(on: DispatchQueue.main)","            .sink(receiveCompletion: { completion in","                switch completion {","                case .finished:","                    break \/\/ normal receive value","                case .failure(let error):","                    \/\/ failure to receive value","                    \/\/ do something with error publisher","                    print(error.localizedDescription)","                }","            }) { [weak self] resultAuthentication in","                switch resultAuthentication {","                    case .success:","                        \/\/ do something after successful authentication","                        \/\/ for example init Vigram services and","                        \/\/ start bluetooth scanning after that","                    case .failure(let error):","                        \/\/ do something with error authentication","                        print(error.localizedDescription)","                }","            }","    }","","    deinit {","        authentication = nil","    }","}"],"syntax":"swift"},{"inlineContent":[{"inlineContent":[{"text":"Return value:","type":"text"}],"type":"strong"},{"text":" Result<Bool, AuthenticationError>","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Throw error:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/AuthenticationError"}],"type":"paragraph"},{"type":"heading","text":"","anchor":"","level":3},{"inlineContent":[{"type":"text","text":"It is recommended to place the authentication call in the initialization of your Vigram helper class to avoid missing the token expiration date (20 days offline)."}],"type":"paragraph"},{"inlineContent":[{"text":"This completes the authentication procedure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The next step is "},{"type":"strong","inlineContent":[{"overridingTitleInlineContent":[{"text":"change the configuration parameters.","type":"text"}],"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step3ConfigurationParameters","overridingTitle":"change the configuration parameters."}]}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}],"type":"emphasis"}],"type":"paragraph"},{"level":3,"anchor":"More-information-about","type":"heading","text":"More information about"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/combine"}]}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitle":"Using Combine and Publishers","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","overridingTitle":"SDK Errors and exceptions","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"Demo repository","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"Demo repository","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/"}]}]}]},{"level":2,"anchor":"Navigation","text":"Navigation","type":"heading"},{"type":"paragraph","inlineContent":[{"overridingTitle":"Up to Getting started with VigramSDK","overridingTitleInlineContent":[{"type":"text","text":"Up to Getting started with VigramSDK"}],"isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","type":"reference"}]},{"type":"paragraph","inlineContent":[{"overridingTitle":"✅ STEP 1 (Import VigramSDK)","overridingTitleInlineContent":[{"text":"✅ STEP 1 (Import VigramSDK)","type":"text"}],"isActive":true,"identifier":"doc:\/\/com.vigramsd