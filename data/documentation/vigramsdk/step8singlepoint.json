{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step8SinglePoint","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","title":"Using Single point measurements","role":"article","images":[{"identifier":"logo.png","type":"icon"}]},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","isActive":true},{"text":" can be used to record single points over a given duration. During the recording phase, the service will keep track of all the environment’s data and then merge individual measurements to one combined single point.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Please make sure that during the recording of single points, there are only minimal position changes, since the recording will otherwise fail.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"It is recommended that you review these sections before proceeding.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/combine","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/corebluetooth","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","type":"reference","isActive":true,"overridingTitle":"Using Combine and Publishers","overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SDKErrorsAndExceptions","type":"reference","isActive":true,"overridingTitle":"SDK Errors and exceptions","overridingTitleInlineContent":[{"text":"SDK Errors and exceptions","type":"text"}]}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Create a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingService","isActive":true},{"text":" to record single points over a given duration with increased accuracy.","type":"text"}],"type":"paragraph"},{"code":["let singlePointService: SinglePointRecordingService = ","    Vigram.singlePointRecordingService(gpsService: gpsService)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If you need to use pedestrian or stationary dynamic state mode viDoc with SinglePoint measurements use this init","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Note","type":"text"}],"type":"strong"},{"text":": This option available on 0.5.5 SDK version or up","type":"text"}],"type":"paragraph"},{"code":["\/\/ Init without laser","let singlePointService: SinglePointRecordingService = ","    Vigram.singlePointRecordingService(gpsService: GPSService, ","                                       peripheral: Peripheral, ","                                       dynamicStateType: DynamicStateType)","\/\/ Init with laser","let singlePointService: SinglePointRecordingService = ","    Vigram.singlePointRecordingService(gpsService: GPSService, ","                                       laserService: LaserService, ","                                       peripheral: Peripheral, ","                                       dynamicStateType: .pedestrian)"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Old protocol methods","anchor":"Old-protocol-methods","type":"heading"},{"inlineContent":[{"text":"On the old protocol version, the setting range for the measurement duration was 5…60. There was also no possibility to interrupt a measurement that had already started.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For start measurement, perform this method","type":"text"}],"type":"paragraph"},{"code":["singlePointService","    .record(duration: duration, ","            updateInterval: updateInterval, ","            with: method)","    .sink(receiveCompletion: { completion in ","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    }) { singlePointValue in","        \/\/ do somethind with singlePointValue","    }.store(in: &subscription)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"inlineContent":[{"text":"Receive value:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","isActive":true}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Throw error:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","isActive":true}],"type":"paragraph"},{"level":3,"text":"More information about","anchor":"More-information-about","type":"heading"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnvironmentData","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService","type":"reference","isActive":true,"overridingTitle":"EnviromentDataService","overridingTitleInlineContent":[{"text":"EnviromentDataService","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","type":"reference","isActive":true,"overridingTitle":"GPSService","overridingTitleInlineContent":[{"text":"GPSService","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService","type":"reference","isActive":true,"overridingTitle":"LaserService","overridingTitleInlineContent":[{"text":"LaserService","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GPSCoordinate","type":"reference","isActive":true,"overridingTitle":"Use GPSCoordinate + Transformation","overridingTitleInlineContent":[{"text":"Use GPSCoordinate + Transformation","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","type":"reference","isActive":true,"overridingTitle":"Using Combine and Publishers","overridingTitleInlineContent":[{"text":"Using Combine and Publishers","type":"text"}]}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"New protocol methods","anchor":"New-protocol-methods","type":"heading"},{"inlineContent":[{"text":"The new version of the protocol has no restrictions on measurement time.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note: If set the duration value to 0, the measurement will go on infinity. If need to terminate measurements, perform the method stopMeasurement.","type":"text"},{"text":" ","type":"text"},{"text":"(Available only on the new protocol - HW of viDoc 0.2.1.(12) and up)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["singlePointRecordingService","    .startMeasurement()","    .sink(receiveCompletion: { completion in ","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    }) { singlePointValue in","        \/\/ do somethind with singlePointValue","    }.store(in: &subscription)"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Receive value:"}]},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","type":"reference","isActive":true}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Throw error:","type":"text"}]},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","isActive":true}],"type":"paragraph"},{"text":"More information about","type":"heading","level":3,"anchor":"More-information-about"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePoint","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnvironmentData"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService","type":"reference","isActive":true,"overridingTitle":"EnviromentDataService","overridingTitleInlineContent":[{"type":"text","text":"EnviromentDataService"}]}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"GPSService","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP","overridingTitleInlineContent":[{"text":"GPSService","type":"text"}],"type":"reference"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"overridingTitle":"LaserService","overridingTitleInlineContent":[{"text":"LaserService","type":"text"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"overridingTitle":"Use GPSCoordinate + Transformation","overridingTitleInlineContent":[{"text":"Use GPSCoordinate + Transformation","type":"text"}],"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GPSCoordinate","isActive":true}]}]},{"content":[{"inlineContent":[{"overridingTitle":"Using Combine and Publishers","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseCombineAndPublishers","overridingTitleInlineContent":[{"type":"text","text":"Using Combine and Publishers"}],"type":"reference"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If needed to stop measurement process, perform stopMeasurement method:","type":"text"}]},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"code":["singlePointRecordingService.stopMeasurement()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If needed to cancel measurement process, perform cancelMeasurement method:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["singlePointRecordingService.cancelMeasurement()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If needed to watch mesurement duration time, use variable measurementTime:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["var measurementTime: StatePublisher<TimeInterval> { get }"]},{"type":"paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["singlePointRecordingService","    .measurementTime","    .sink { value in","        \/\/ do somethind with value","    }.store(in: &subscription)"]},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"All methods and functions specified in this manual are also available in the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/vigram-sw\/SDK_iOS_viDoc_Distribution\/tree\/demo\/","isActive":true}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"An important section is "},{"type":"reference","isActive":true,"overridingTitle":"Use Antenna Offsets","overridingTitleInlineContent":[{"type":"text","text":"Use Antenna Offsets"}],"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseAntennaOffsets"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Note: Offsets have a data type ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/simd3","type":"reference"}]},{"type":"paragraph","inlineContent":[{"text":"You can set your own custom offsets","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let yourCustomOffset = SIMD3(x: 4.4, y: -1.6, z: 2) \/ 100"]},{"text":"Detailed listing Single Point measurements with laser","type":"heading","level":2,"anchor":"Detailed-listing-Single-Point-measurements-with-laser"},{"syntax":"swift","type":"codeListing","code":["\/\/ Bottom laser selected (or .back if needed)","let typeOfLaser: LaserConfiguration.Position = .bottom","","\/\/ Laser measurement mode - fast","let laserShotMode: LaserConfiguration.ShotMode = .fast ","","\/\/ Measurement duration (in seconds). ","\/\/ For viDoc protocol version < 2, the measurement duration","\/\/ must be in the range [5...60] seconds.","\/\/","\/\/ For protocol >= 2, any value can be specified. If 0 is ","\/\/ specified, the measurement will continue ","\/\/ indefinitely.","\/\/ ","\/\/ More details in section №8 (Using Single point measurements)","let duration: Double = 30","","\/\/ Creating a laser configuration. ","\/\/ The laser configuration. Keep in mind, that you will not receive ","\/\/ further environment data values after the laser duration has passed.","let laserConfig = LaserConfiguration.init(shotMode: laserShotMode, ","                                          position: typeOfLaser, ","                                          duration: duration)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.Laser.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ UseDeviceMotion - This attribute specifies whether to incorporate ","\/\/ the device motion into the calculation of the corrected coordinate. ","\/\/ This allows to not only correct coordinates by strictly subtracting ","\/\/ the laser distance measurement from the measured antenna position,","\/\/ but rather enables diagonally held laser measurements as well.","let method = ","    CoordinateCorrection.Method.laser(configuration: laserConfig, ","                                      antennaOffset: offset,","                                      useDeviceMotion: true)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  laserService: laserService!,","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","\/\/ Start SinglePoint measurements","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }","","\/\/ For stop measurement use this method","\/\/ Important! Use it only when setting the time to 0 (infinite ","\/\/ measurement). After executing this method, the measurement ","\/\/ will end.","singlePointRecordingService!.stopMeasurement()","","\/\/ Important! Use only when time is set to 0 ","\/\/ (infinite measurement). ","\/\/ After this method is executed, the measurement will stop. ","\/\/ The data will NOT BE SAVED.","singlePointRecordingService?.cancelMeasurement()","","\/\/ If you are using an infinite measurement (duration - 0) ","\/\/ and need to track the time of the dimension,","\/\/ use this publisher.","\/\/ Note: The time will starts after the first successful laser ","\/\/ measurement (quality >= acceptable)","let cancellable = singlePointRecordingService!","    .measurementTime","    .sink { time in","        \/\/ do something with measurement time","    }"]},{"text":"Detailed listing Single Point measurements without laser","type":"heading","level":2,"anchor":"Detailed-listing-Single-Point-measurements-without-laser"},{"type":"codeListing","code":["\/\/ The distance from the antenna to the ground to subtract from the ","\/\/ antenna’s coordinate’s altitude.","let distanceToGround = Double(distanceToGround)","","\/\/ Antenna offset","\/\/ The offset of the laser in relation to the antenna position. ","\/\/ Use values from AntennaOffset here.","let currentOffsets = AntennaOffset.SPC.iPhone14ProMaxBottom","","\/\/ Measurement method","\/\/ When using the constant height coordinate correction,","\/\/ the correctedCoordinate property of EnvironmentData will reflect ","\/\/ the position of the antenna with an altitude subtracted by the ","\/\/ constant value.","let method = ","    CoordinateCorrection.Method","        .constant(distanceFromAntennaToGround: antennaDistanceToGround)","","\/\/ Creates an EnvironmentDataService to keep track of all the environment ","\/\/ information from the device’s internal sensors and possible values  ","\/\/ from the viDoc sensors.","\/\/","\/\/ DynamicStateType - Pedestrian or Stationary type of dynamic state","let environmentDataService = ","    Vigram.environmentDataService(gpsService: gpsService!, ","                                  peripheral: peripheral!, ","                                  dynamicStateType: .stationary)","","\/\/ Create SinglePoint Recording Service","let singlePointRecordingService = ","    Vigram.singlePointRecordingService(environmentDataService: ","                                        environmentDataService!)","","let cancellable = singlePointRecordingService!","    .startMeasurement(duration: duration, ","                      updateInterval: 0.1, with: method)","    .sink { completion in","        switch completion {","        case .finished:","            \/\/ Value successfully received","            \/\/ You can use this state for any further actions ","            \/\/ after receiving the values.","            break","        case let .failure(error):","            \/\/ Error getting value","            \/\/ Do something with error","            print(error.localizedDescription)","        }","    } receiveValue: { singlePoint in","        \/\/ Do something with singlePoint","    }"],"syntax":"swift"},{"type":"heading","anchor":"SinglePointRecordingError","text":"SinglePointRecordingError","level":3},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/SinglePointRecordingError","type":"reference","isActive":true},{"text":" are thrown, when due to the filtering phase of single point recordings there is not enough valid data to create a singlePoint. To investigate possible issues with the measurement, have a look at the provided associated data.","type":"text"}]},{"type":"codeListing","code":["public enum SinglePointRecordingError: Error, Hashable {","","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/","\/\/ Available in SDK ver. 1.0.3","case nonValidData","","\/\/ This method is not supported in current software version of ","\/\/ the RTK device","\/\/","\/\/ Available in SDK ver. 1.0.3","case requestIsNotSupported(String)","","\/\/ The correction method used has incorrect settings","\/\/ Most likely the CoordinateCorrectionMethod settings ","\/\/ were not selected and passed to the write method correctly","\/\/","\/\/ Available in SDK ver. 1.0.3","case incorrectCoordinateCorrectionMethod(String)","","\/\/ Running measurement process not found","\/\/","\/\/ Available in SDK ver. 1.0.3","case noRunningMeasurementMethod","","\/\/ The value of horizontal accuracy is too high","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case horizontalAccuracyIsTooHigh","","\/\/ The value of vertical accuracy is too high","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/","\/\/ Available in SDK ver. 1.0.3","case verticalAccuracyIsTooHigh","","\/\/ The value of altitude difference is too high","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/","\/\/ Available in SDK ver. 1.0.3","case altitudeDifferenceIsTooHigh","","\/\/ The laser measurements are of bad quality","\/\/","\/\/ This means that most of the laser measurements were of bad ","\/\/ quality or incorrect.","\/\/","\/\/ Available in SDK ver. 1.0.3","case laserMeasurementsIsBadQuality","","\/\/ The measurement cancelled by user.","case measurementCancelled","","\/\/ Deprecated!","\/\/","\/\/ The measurement failed due to too much filtered, non-valid data","\/\/ Most of the measured data have low accuracy.","\/\/ e.g. One or more conditions are not met","\/\/ Hor.Accuracy < Configuration.maximumSinglePointHorizontalAccuracy,","\/\/ Vert.Accuracy < Configuration.maximumSinglePointVerticalAccuracy","\/\/ Altitude < Configuration.maximumSinglePointAltitudeDifference","\/\/ The returned RAW value of this error is the received measurements.","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case badMeasurement([EnvironmentData])","","\/\/ Deprecated!","\/\/","\/\/ The measurement failure.","\/\/ In most cases this error is not returned. ","\/\/ If you get it, check if you passed the correct ","\/\/ CoordinateCorrection.Method to the SinglePointRecordingService ","\/\/ measurement procedure (record or startMeasurements).","\/\/","\/\/ This error was used in older versions of SDK. Will not be","\/\/ supported in the future","case measurementFailure","}"],"syntax":"swift"},{"type":"heading","anchor":"More-information-about","text":"More information about","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"Peripheral"}],"isActive":true,"type":"reference","overridingTitle":"Peripheral","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step5WorkWithPeripheral"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"GPSService"}],"isActive":true,"type":"reference","overridingTitle":"GPSService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step6UsingNTRIP"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"LaserService"}],"isActive":true,"type":"reference","overridingTitle":"LaserService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step7LaserService"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"EnviromentDataService"}],"isActive":true,"type":"reference","overridingTitle":"EnviromentDataService","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/EnviromentDataService"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"Use GPSCoordinate + Transformation"}],"isActive":true,"type":"reference","overridingTitle":"Use GPSCoordinate + Transformation","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GPSCoordinate"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Navigation","text":"Navigation","level":2},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"Up to Getting started with VigramSDK","type":"text"}],"overridingTitle":"Up to Getting started with VigramSDK","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/GettingStarted","type":"reference","isActive":true}]},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"✅ STEP 1 (Import VigramSDK)","type":"text"}],"overridingTitle":"✅ STEP 1 (Import VigramSDK)","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/Step1GettingStarted","type":"reference","isActive":true}]},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"✅ STEP 2 (SDK Authentication)","type":"text"}],"overridingTitle":"✅ STEP 2 (SDK Authentication)","identifier":"doc:\/\/com.vigramsdk\/do