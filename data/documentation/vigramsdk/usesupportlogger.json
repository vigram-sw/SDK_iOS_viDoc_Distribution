{"kind":"article","sections":[],"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"content":[{"anchor":"","text":"","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Create one structured support logger file and let the SDK write JSON Lines ("},{"type":"codeVoice","code":".jsonl"},{"type":"text","text":") into it."},{"type":"text","text":" "},{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"After that, configure the SDK logger once:"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need a deeper trace for support, switch to diagnostic mode:"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The SDK writes structured support events into this file automatically."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Use Support Logger","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"VigramSDK"}],"roleHeading":"Article","role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/usesupportlogger"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger"},"references":{"doc://com.vigramsdk/documentation/VigramSDK":{"role":"collection","kind":"symbol","url":"\/documentation\/vigramsdk","images":[{"type":"icon","identifier":"logo.png"}],"title":"VigramSDK","abstract":[],"type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"logo.png":{"variants":[{"url":"\/images\/com.vigramsdk\/logo.png","traits":["1x","light"]}],"identifier":"logo.png","alt":"Vigram logo.","type":"image"}}}