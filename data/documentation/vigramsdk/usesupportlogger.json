{"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UseSupportLogger","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","metadata":{"roleHeading":"Article","modules":[{"name":"VigramSDK"}],"role":"article","images":[{"identifier":"logo.png","type":"icon"}],"title":"Use Support Logger"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"","type":"heading","anchor":""},{"type":"paragraph","inlineContent":[{"text":"Create one structured support logger file and let the SDK write JSON Lines (","type":"text"},{"code":".jsonl","type":"codeVoice"},{"text":") into it.","type":"text"},{"text":" ","type":"text"},{"text":"Example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"basic_17.04.2026-21:18:12.jsonl\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(for: .documentDirectory, ","                                 in: .userDomainMask)","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(atPath: path, ","                        withIntermediateDirectories: true, ","                        attributes: nil)","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"]},{"inlineContent":[{"text":"After that, configure the SDK logger once:","type":"text"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .basic)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If you need a deeper trace for support, switch to diagnostic mode:","type":"text"}],"type":"paragraph"},{"code":["if let path {","    try Vigram.Logger(url: path, mode: .diagnostic)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The SDK writes structured support events into this file automatically.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/usesupportlogger"]}],"references":{"logo.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"identifier":"logo.png","type":"image","alt":"Vigram logo."},"doc://com.vigramsdk/documentation/VigramSDK":{"type":"topic","title":"VigramSDK","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK","abstract":[],"kind":"symbol","role":"collection","url":"\/documentation\/vigramsdk","images":[{"type":"icon","identifier":"logo.png"}]}}}