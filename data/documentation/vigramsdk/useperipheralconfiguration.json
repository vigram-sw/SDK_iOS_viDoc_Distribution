{"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"metadata":{"modules":[{"name":"VigramSDK"}],"role":"article","images":[{"identifier":"logo.png","type":"icon"}],"roleHeading":"Article","title":"Use Peripheral Configuration"},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"]}],"identifier":{"url":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/UsePeripheralConfiguration","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"","anchor":""},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},{"type":"text","text":" and pass it to the peripheral initializer."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then pass the configuration to the peripheral initializer:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"]},{"type":"paragraph","inlineContent":[{"text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation used in navigation is set to 10 degrees","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellations are active","glonassActivate = true","beidouActivate = true","galileoActivate = true","qzssActivate = true","sbassActivate = true","","\/\/ NAV-DOP and NAV-PVT messages are active","navDOPActivate = true","navPVTActivate = true","","\/\/ Dynamic state mode","dynamicType = .pedestrian"]}],"kind":"content"}],"references":{"logo.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/com.vigramsdk\/logo.png"}],"identifier":"logo.png","alt":"Vigram logo.","type":"image"},"doc://com.vigramsdk/documentation/VigramSDK":{"role":"collection","kind":"symbol","url":"\/documentation\/vigramsdk","images":[{"type":"icon","identifier":"logo.png"}],"title":"VigramSDK","abstract":[],"type":"topic","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK"},"doc://com.vigramsdk/documentation/VigramSDK/PeripheralConfiguration":{"url":"\/documentation\/vigramsdk\/peripheralconfiguration","role":"symbol","kind":"symbol","abstract":[{"text":"Initial configuration for peripheral","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"PeripheralConfiguration"}],"title":"PeripheralConfiguration","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PeripheralConfiguration"}],"type":"topic"}}}