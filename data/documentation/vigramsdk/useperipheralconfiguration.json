{"metadata":{"images":[{"type":"icon","identifier":"logo.png"}],"title":"Use Peripheral Configuration","role":"article","modules":[{"name":"VigramSDK"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.vigramsdk\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"","anchor":""},{"type":"paragraph","inlineContent":[{"text":"If you need to disable some GNSS messages, change the message rate, or change the minimum elevation used in navigation parameters, create a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.vigramsdk\/documentation\/VigramSDK\/PeripheralConfiguration"},{"text":" and pass it to the peripheral initializer.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let peripheralConfiguration =","    PeripheralConfiguration(rateOfChangeMessages: .hertz1,","                            glonassActivate: false)"]},{"inlineContent":[{"text":"Then pass the configuration to the peripheral initializer:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ If use support logger, configure it once with Vigram.Logger(...)","\/\/ and then create the peripheral normally","let sdkPeripheral =","    Vigram.peripheral(cbPeripheral,","                      configuration: peripheralConfiguration)","","\/\/ Without a custom configuration","let defaultPeripheral = Vigram.peripheral(cbPeripheral)"]},{"inlineContent":[{"type":"text","text":"Note: If this parameter is not passed to the initializer, all parameters will use their default values."}],"type":"paragraph"},{"code":["\/\/ Message rate is set to 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation used in navigation is set to 10 degrees","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellations are active","glonassActivate = true","beidouActiva